---
import Layout from '../layouts/Layout.astro';
import TrustedBy from '../components/TrustedBy.astro';
---
<Layout
	title="Wedding Catering Vancouver | Indian, Halal, Vegan Wedding Catering | Sula"
	description="Award-winning wedding catering Vancouver since 2010. Indian wedding catering for sangeet, ceremony, reception. Halal, vegetarian, vegan, Jain. From $45 per guest."
	canonical="/weddings"
	ogImage="/uploads/indian-wedding-catering.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org","@type": "Service",
			"name": "Wedding Catering Vancouver",
			"provider": {"@id": "https://sulacatering.com/#organization"},
			"areaServed": ["Vancouver", "Burnaby", "Richmond", "Surrey", "North Vancouver"],
			"serviceType": "Wedding Catering"
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org","@type": "FAQPage",
			"mainEntity": [
				{"@type":"Question","name":"Do you offer halal wedding catering in Vancouver?","acceptedAnswer":{"@type":"Answer","text":"Yes, all our chicken and lamb dishes are prepared using halal-certified meats sourced from trusted local BC suppliers."}},
				{"@type":"Question","name":"Can you do affordable wedding catering for smaller weddings?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. We cater weddings from 50 guests upward, with pricing that scales with menu and service style."}},
				{"@type":"Question","name":"Do you provide vegan and Jain wedding catering?","acceptedAnswer":{"@type":"Answer","text":"Yes. We offer dedicated vegan, vegetarian, and Jain menus prepared in separate kitchen areas."}},
				{"@type":"Question","name":"What's your minimum guest count for wedding catering?","acceptedAnswer":{"@type":"Answer","text":"We cater weddings from 50 to 500+ guests."}},
				{"@type":"Question","name":"How far in advance should we book wedding catering?","acceptedAnswer":{"@type":"Answer","text":"For peak season (May–October), 6–9 months in advance."}}
			]
		})} />
	</Fragment>

	<section class="hero" style="background-image: linear-gradient(135deg, rgba(74,21,84,0.75) 0%, rgba(37,4,45,0.7) 50%, rgba(20,8,16,0.85) 100%), url('/uploads/indian-wedding-catering.webp');">
		<div class="hero-content">
			<h1>Indian Wedding<br/>Catering in <em>Vancouver</em></h1>
			<p class="hero-tagline">From sangeet to reception, flawless execution, exquisite presentation, and the warmth of true Indian hospitality.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request a Wedding Quote</a>
		</div>
	</section>

	<TrustedBy />


	<section class="section section-cream">
		<div class="container">
			<div class="intro-block reveal">
				<h2>Your Wedding, <em>Our Honour</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p>We've been doing wedding catering in Vancouver since 2010, hundreds of South Asian weddings across the Lower Mainland, from intimate Sikh ceremonies of 80 guests to multi-day Hindu weddings of 500. <a href="/" class="body-link">Sula Catering</a> brings fifteen years of experience to every event, with chefs trained in North Indian, South Indian, Hyderabadi, and Goan cuisine. Read our <a href="/blog/indian-wedding-catering-vancouver-guide" class="body-link">complete wedding planning guide</a>, or browse our <a href="/gallery" class="body-link">wedding gallery</a>.</p>
			</div>
		</div>
	</section>

	<img src="/uploads/wedding-catering-vancouver-bc.webp" alt="Indian wedding catering Vancouver BC" class="full-width-image" loading="lazy" />

	<section class="section section-plum pattern-mandala">
		<div class="container">
			<div class="text-center reveal" style="margin-bottom:80px">
				<p class="eyebrow">Three Events. One Family.</p>
				<h2 class="mag-title">From Sangeet to <em>Reception</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="alt-row">
				<div class="alt-row-img reveal-left">
					<img src="/uploads/wedding-catering-burnaby-vancouver.webp" alt="Sangeet catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-right">
					<h2>Sangeet, Live Stations, <em>Lively Nights</em></h2>
					<p>Pani puri at the chaat counter. Dosas crisping at the tava station. Tandoori chicken tikka straight off the grill. Live cooking turns pre-wedding events into immersive experiences.</p>
					<p>Pair with a <a href="/cafe-catering" class="body-link">live masala chai bar</a> for a complete sensory experience.</p>
				</div>
			</div>
			<div class="alt-row reverse">
				<div class="alt-row-img reveal-right">
					<img src="/uploads/Indian-food-catering-vancouver-burnaby-richmond-office.webp" alt="Wedding ceremony catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-left">
					<h2>Ceremony, Vegetarian Feasts, <em>Honoured Traditions</em></h2>
					<p>Pure-vegetarian thalis and Jain-friendly buffets prepared in dedicated kitchen areas. Paneer butter masala. Dal makhani. Vegetable biryani. Honouring religious traditions has always been at the heart of how we cater.</p>
				</div>
			</div>
			<div class="alt-row">
				<div class="alt-row-img reveal-left">
					<img src="/uploads/indian-food-catering-near-me-vancouver-bc.webp" alt="Wedding reception catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-right">
					<h2>Reception, The Main Event, <em>Perfectly Plated</em></h2>
					<p>Butter chicken. Lamb rogan josh. Hyderabadi dum biryani. Plated dinner catering or premium buffet, with <a href="/blog/halal-indian-catering-vancouver" class="body-link">halal-certified meats</a> and dessert spreads featuring gulab jamun and ras malai.</p>
				</div>
			</div>
		</div>
	</section>

	<div class="image-banner image-banner-plum" style="background-image: url('/uploads/indian-wedding-catering.webp');">
		<div class="image-banner-content reveal">
			<h2>Every Detail, <em>Considered</em></h2>
			<p>From dietary needs to dietary dreams, we say yes.</p>
		</div>
	</div>

	<section class="section section-cream">
		<div class="container-narrow">
			<div class="text-center reveal">
				<p class="eyebrow">Full-Service Wedding Catering</p>
				<h2 class="mag-title">What's <em>Included</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="numbered-list">
				<div class="numbered-item reveal"><div class="numbered-num">01</div><div class="numbered-content"><h3><em>Custom</em> Menus</h3><p>Build your menu with our chef. Vegan, Jain, gluten-friendly, regional preferences welcome. Tastings available before final approval.</p></div></div>
				<div class="numbered-item reveal"><div class="numbered-num">02</div><div class="numbered-content"><h3>Dedicated <em>Coordinator</em></h3><p>One point of contact from your first email to the final cleanup. We handle the timeline so you can focus on the moments that matter.</p></div></div>
				<div class="numbered-item reveal"><div class="numbered-num">03</div><div class="numbered-content"><h3>Live <em>Cooking Stations</em></h3><p>Chaat counters with dahi puri and pani puri. Dosa stations. Tandoori grills. Live cooking turns dinner into theatre.</p></div></div>
				<div class="numbered-item reveal"><div class="numbered-num">04</div><div class="numbered-content"><h3>Setup <em>& Cleanup</em></h3><p>Buffets, plated service, professional servers. We arrive early, set up beautifully, and leave the venue spotless.</p></div></div>
			</div>
		</div>
	</section>

	<section class="section section-dark pattern-damask">
		<div class="container">
			<div class="testimonial-block reveal">
				<p class="testimonial-quote">We had over 400 guests and Sula handled every single dietary requirement, vegan, Jain, halal, gluten-free. Not one complaint. The chaat station was the talk of the night.</p>
				<p class="testimonial-author">  Aanya & Rohan · Reception, 420 Guests</p>
			</div>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Common Questions</p>
				<h2 class="mag-title">Wedding Catering <em>FAQs</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="faq-list">
				<div class="faq-item reveal"><h3>Do you offer halal wedding catering in Vancouver?</h3><p>Yes, all our chicken and lamb dishes use halal-certified meats sourced from trusted local BC suppliers.</p></div>
				<div class="faq-item reveal"><h3>Can you do affordable wedding catering for smaller weddings?</h3><p>Absolutely. We cater weddings from 50 guests upward, pricing scales with menu complexity, service style, and live stations.</p></div>
				<div class="faq-item reveal"><h3>Do you provide vegan and Jain wedding catering?</h3><p>Yes. Our vegan, vegetarian, and Jain menus are prepared in dedicated kitchen areas to honour every tradition.</p></div>
				<div class="faq-item reveal"><h3>What's the minimum guest count?</h3><p>50 guests for full-service wedding catering. Intimate ceremonies are also welcome, reach out and we'll find a way.</p></div>
				<div class="faq-item reveal"><h3>How far in advance should we book?</h3><p>For peak season (May–October), 6–9 months in advance. Off-season is flexible.</p></div>
				<div class="faq-item reveal"><h3>Can you cater the rehearsal dinner separately?</h3><p>Of course. Many couples book us for the rehearsal dinner, sangeet, and reception as a package, single coordinator, consistent menu vision.</p></div>
			</div>
		</div>
	</section>

	<section class="section section-plum pattern-lotus">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Continue Exploring</p>
				<h2 class="mag-title">More for Your <em>Wedding</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="related-links">
				<a href="/cafe-catering" class="related-link reveal">
					<div class="related-link-img"><img src="/uploads/indian-wedding-catering.webp" alt="" /></div>

					<p class="meta">Service · Café Catering</p>
					<h4>Add a <em>Live Chai Bar</em></h4>
					<p>Bring Sula Café to your wedding, masala chai stations, specialty coffee, fresh-baked pastries.</p>
					<span class="arrow">Explore Café Catering →</span>
				</a>
				<a href="/gallery" class="related-link reveal delay-100">
					<div class="related-link-img"><img src="/uploads/indian-wedding-catering.webp" alt="" /></div>
					<p class="meta">Gallery</p>
					<h4>Wedding <em>Gallery</em></h4>
					<p>See real Vancouver weddings we've catered, sangeets, ceremonies, receptions.</p>
					<span class="arrow">View Gallery →</span>
				</a>
				<a href="/blog/chai-coffee-catering-weddings" class="related-link reveal delay-200">
					<div class="related-link-img"><img src="/uploads/indian-wedding-catering.webp" alt="" /></div>

					<p class="meta">Journal · 5 min</p>
					<h4>Chai vs <em>Coffee</em></h4>
					<p>Why both belong at your wedding, building the perfect beverage program.</p>
					<span class="arrow">Read More →</span>
				</a>
			</div>
		</div>
	</section>


	<section class="cta-section cta-plum">
		<div class="reveal">
			<h2>Let's Plan Your <em>Wedding</em></h2>
			<p>Tell us about your event. We'll respond within 24 hours with a custom menu and quote.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request a Wedding Quote</a>
		</div>
	</section>

</Layout>
