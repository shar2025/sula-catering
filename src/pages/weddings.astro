---
import Layout from '../layouts/Layout.astro';
---
<Layout
	title="Indian Wedding Catering Vancouver | Halal, Vegetarian, Vegan | Sula"
	description="Award-winning Indian wedding catering in Vancouver. Sangeet, ceremony, reception menus. Halal-certified, vegetarian, vegan, Jain options. 15+ years, 2,000+ events."
	canonical="/weddings"
	ogImage="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/01/WEDDING.jpg"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org","@type": "Service",
			"name": "Indian Wedding Catering Vancouver",
			"provider": {"@id": "https://sulacatering.com/#organization"},
			"areaServed": ["Vancouver", "Burnaby", "Richmond", "Surrey", "North Vancouver"],
			"serviceType": "Wedding Catering",
			"description": "Custom Indian wedding catering in Vancouver — sangeet, ceremony, and reception menus with halal, vegetarian, vegan, and Jain options."
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org","@type": "FAQPage",
			"mainEntity": [
				{"@type":"Question","name":"Do you offer halal meat for Indian wedding catering?","acceptedAnswer":{"@type":"Answer","text":"Yes — all chicken and lamb dishes are prepared using halal-certified meats sourced from trusted local BC suppliers."}},
				{"@type":"Question","name":"Can you cater pure-vegetarian or Jain weddings?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. We offer dedicated vegetarian, vegan, and Jain menus prepared in separate kitchen areas."}},
				{"@type":"Question","name":"What is your minimum guest count for weddings?","acceptedAnswer":{"@type":"Answer","text":"We cater weddings from 50 to 500+ guests. Smaller intimate events also welcome."}},
				{"@type":"Question","name":"Do you provide servers and setup for weddings?","acceptedAnswer":{"@type":"Answer","text":"Yes — full-service catering includes setup, professional servers, buffet management, and complete cleanup."}},
				{"@type":"Question","name":"How far in advance should we book wedding catering?","acceptedAnswer":{"@type":"Answer","text":"For peak season (May–October), book 6–9 months in advance. Off-season bookings are flexible."}}
			]
		})} />
	</Fragment>

	<section class="hero" style="background-image: linear-gradient(135deg, rgba(20,8,16,0.85) 0%, rgba(38,14,38,0.7) 50%, rgba(20,8,16,0.9) 100%), url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/01/WEDDING.jpg');">
		<div class="hero-content">
			<p class="gold-label">Wedding Catering</p>
			<h1>Indian Wedding Catering<br/>in <em>Vancouver</em></h1>
			<p class="hero-tagline">From sangeet to reception — flawless execution, exquisite presentation, and the warmth of true Indian hospitality.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request a Wedding Quote</a>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="intro-block reveal">
				<p class="gold-label">Tradition Meets Excellence</p>
				<h2>Your Wedding, <em>Our Honour</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p>Sula has catered hundreds of South Asian weddings across the Lower Mainland. Every event is led by a dedicated wedding coordinator and supported by a kitchen team trained in the regional cuisines of India. Browse our <a href="/gallery" style="color:var(--gold);border-bottom:1px solid var(--gold)">wedding gallery</a> or read our <a href="/blog/indian-wedding-catering-vancouver-guide" style="color:var(--gold);border-bottom:1px solid var(--gold)">complete wedding planning guide</a> to see how we work.</p>
			</div>
		</div>
	</section>

	<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddinf-catering-vancouver-bc.webp" alt="Indian wedding catering Vancouver BC" class="full-width-image" loading="lazy" />

	<section class="section section-plum">
		<div class="container">
			<div class="text-center reveal" style="margin-bottom:80px">
				<p class="eyebrow">Three Events. One Family.</p>
				<h2 class="mag-title">From Sangeet to <em>Reception</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="alt-row">
				<div class="alt-row-img reveal-left">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddin-catering-burnaby-vancouver.webp" alt="Sangeet catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-right">
					<p class="gold-label">Sangeet & Mehndi</p>
					<h2>Live Stations, <em>Lively Nights</em></h2>
					<p>Pani puri at the chaat counter. Dosas crisping at the tava station. Chai pouring from copper urns. Our live cooking stations turn pre-wedding events into immersive experiences.</p>
					<p>Pair with our <a href="/cafe-catering" style="color:var(--gold-light);border-bottom:1px solid var(--gold)">chai bar from Sula Café</a> for a complete sensory experience.</p>
				</div>
			</div>
			<div class="alt-row reverse">
				<div class="alt-row-img reveal-right">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/Indian-food-catering-vancouver-burnaby-richmond.webp" alt="Wedding ceremony catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-left">
					<p class="gold-label">Ceremony Lunches</p>
					<h2>Vegetarian Feasts, <em>Honoured Traditions</em></h2>
					<p>Pure-vegetarian thalis and Jain-friendly buffets prepared in dedicated kitchen areas. Honouring religious traditions has always been at the heart of how we cater.</p>
				</div>
			</div>
			<div class="alt-row">
				<div class="alt-row-img reveal-left">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-food-catering-near-me-vancouver-bc.webp" alt="Wedding reception catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-right">
					<p class="gold-label">Reception Dinners</p>
					<h2>The Main Event, <em>Perfectly Plated</em></h2>
					<p>North Indian, South Indian, and Indo-Chinese feasts featuring <a href="/blog/halal-indian-catering-vancouver" style="color:var(--gold-light);border-bottom:1px solid var(--gold)">halal-certified meats</a>, tandoori specialties, and dessert spreads.</p>
				</div>
			</div>
		</div>
	</section>

	<div class="image-banner image-banner-plum" style="background-image: url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/01/WEDDING.jpg');">
		<div class="image-banner-content reveal">
			<h2>Every Detail, <em>Considered</em></h2>
			<p>From dietary needs to dietary dreams — we say yes.</p>
		</div>
	</div>

	<section class="section section-cream">
		<div class="container-narrow">
			<div class="text-center reveal">
				<p class="eyebrow">Full-Service Wedding Catering</p>
				<h2 class="mag-title">What's <em>Included</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="numbered-list">
				<div class="numbered-item reveal"><div class="numbered-num">01</div><div class="numbered-content"><h3><em>Custom</em> Menus</h3><p>Build your menu with our chef. Vegan, Jain, gluten-friendly, regional preferences welcome. Tastings available before final approval.</p></div></div>
				<div class="numbered-item reveal"><div class="numbered-num">02</div><div class="numbered-content"><h3>Dedicated <em>Coordinator</em></h3><p>One point of contact from your first email to the final cleanup. We handle the timeline so you can focus on the moments that matter.</p></div></div>
				<div class="numbered-item reveal"><div class="numbered-num">03</div><div class="numbered-content"><h3>Live <em>Cooking Stations</em></h3><p>Chaat counters, dosa stations, tandoori grills. Live cooking turns dinner into theatre — and brings guests together.</p></div></div>
				<div class="numbered-item reveal"><div class="numbered-num">04</div><div class="numbered-content"><h3>Setup <em>& Cleanup</em></h3><p>Buffets, plated service, professional servers. We arrive early, set up beautifully, and leave the venue spotless.</p></div></div>
			</div>
		</div>
	</section>

	<section class="section section-dark">
		<div class="container">
			<div class="testimonial-block reveal">
				<p class="gold-label">From Our Couples</p>
				<p class="testimonial-quote">We had over 400 guests and Sula handled every single dietary requirement — vegan, Jain, halal, gluten-free. Not one complaint. The chaat station was the talk of the night.</p>
				<p class="testimonial-author">— Aanya & Rohan · Reception, 420 Guests</p>
			</div>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Common Questions</p>
				<h2 class="mag-title">Wedding Catering <em>FAQs</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="faq-list">
				<div class="faq-item reveal"><h3>Do you offer halal meat?</h3><p>Yes — all chicken and lamb dishes are prepared using halal-certified meats. Read more in our <a href="/blog/halal-indian-catering-vancouver">halal catering guide</a>.</p></div>
				<div class="faq-item reveal"><h3>Can you cater pure-vegetarian or Jain weddings?</h3><p>Absolutely. We offer dedicated vegetarian, vegan, and Jain menus prepared in separate kitchen areas.</p></div>
				<div class="faq-item reveal"><h3>What's your minimum guest count?</h3><p>We cater weddings from 50 to 500+ guests. Smaller intimate events also welcome.</p></div>
				<div class="faq-item reveal"><h3>Do you provide servers and setup?</h3><p>Yes — full-service catering includes setup, professional servers, buffet management, and complete cleanup.</p></div>
				<div class="faq-item reveal"><h3>How far in advance should we book?</h3><p>For peak season (May–October), 6–9 months in advance. Off-season bookings are flexible.</p></div>
			</div>
		</div>
	</section>

	<!-- RELATED PAGES (internal linking boost) -->
	<section class="section section-plum">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Continue Exploring</p>
				<h2 class="mag-title">More for Your <em>Wedding</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="related-links">
				<a href="/cafe-catering" class="related-link reveal">
					<p class="meta">Service · Café Catering</p>
					<h4>Add a <em>Live Chai Bar</em></h4>
					<p>Bring Sula Café to your wedding — live chai stations, specialty coffee, freshly baked goods.</p>
					<span class="arrow">Explore Café Catering →</span>
				</a>
				<a href="/gallery" class="related-link reveal delay-100">
					<p class="meta">Gallery</p>
					<h4>Wedding <em>Gallery</em></h4>
					<p>See real Vancouver weddings we've catered — from intimate ceremonies to grand receptions.</p>
					<span class="arrow">View Gallery →</span>
				</a>
				<a href="/blog/chai-coffee-catering-weddings" class="related-link reveal delay-200">
					<p class="meta">Journal · 5 min</p>
					<h4>Chai vs <em>Coffee</em></h4>
					<p>Why both belong at your wedding — building the perfect beverage program for your guests.</p>
					<span class="arrow">Read More →</span>
				</a>
			</div>
		</div>
	</section>

	<section class="cta-section cta-plum">
		<div class="reveal">
			<p class="gold-label" style="color:var(--gold-light)">Begin the Conversation</p>
			<h2>Let's Plan Your <em>Wedding</em></h2>
			<p>Tell us about your event. We'll respond within 24 hours with a custom menu and quote.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request a Wedding Quote</a>
		</div>
	</section>

</Layout>
