---
import Layout from '../layouts/Layout.astro';
---
<Layout
	title="Sula Café Catering Vancouver | Chai, Coffee & Bakery Catering"
	description="Live chai stations, specialty coffee, fresh-baked goods, and Indian street food catering from Sula Café. Perfect for office breakfasts, weddings, and private events in Vancouver."
	canonical="/cafe-catering"
	ogImage="https://sulacafe.com/wp-content/uploads/2026/02/sula-cafe-near-me-vancouver.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Service",
			"name": "Sula Café Catering Vancouver",
			"provider": {"@id": "https://sulacatering.com/#organization"},
			"areaServed": ["Vancouver", "Burnaby", "Richmond", "Surrey", "North Vancouver"],
			"serviceType": "Café Catering",
			"description": "Live chai stations, specialty coffee, fresh-baked Indian pastries, and street food catering from Sula Café — for office breakfasts, weddings, and private events."
		})} />
	</Fragment>

	<!-- HERO -->
	<section class="hero" style="background-image: linear-gradient(135deg, rgba(20,8,16,0.85) 0%, rgba(38,14,38,0.6) 50%, rgba(20,8,16,0.85) 100%), url('https://sulacafe.com/wp-content/uploads/2026/02/sula-cafe-near-me-vancouver.webp');">
		<div class="hero-content">
			<p class="gold-label">Sula Café Catering</p>
			<h1>Chai, Coffee &<br/><em>Café Catering</em></h1>
			<p class="hero-tagline">Live chai stations, specialty coffee bars, fresh-baked Indian pastries, and street-food experiences — directly from our café in East Van.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request Café Catering</a>
		</div>
	</section>

	<!-- INTRO -->
	<section class="section section-cream">
		<div class="container">
			<div class="intro-block reveal">
				<p class="gold-label">From Sula Café · East Vancouver</p>
				<h2>The Café <em>Experience</em>, On Location</h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<p>Sula Café is more than chai and pastries — it's a love letter to morning rituals, slow conversations, and the kind of food that makes a room feel like home. We bring all of it to your event: the live chai bar, the espresso machines, the freshly baked koliyada, the steaming pav bhaji. Office breakfasts, wedding morning rituals, late-night street-food bars at receptions — wherever you need warmth, we'll bring it.</p>
			</div>
		</div>
	</section>

	<!-- FULL-WIDTH IMAGE -->
	<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/masala-chai-sula-indian-restaurant.webp" alt="Sula Cafe masala chai catering Vancouver" class="full-width-image" loading="lazy" />

	<!-- WHAT WE OFFER - menu cards -->
	<section class="section section-cream">
		<div class="container-narrow">
			<div class="text-center reveal">
				<p class="eyebrow">Our Café Catering Menu</p>
				<h2 class="mag-title">Stations &amp; <em>Specialties</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<p style="max-width:680px;margin:0 auto;font-size:16px;color:rgba(26,26,26,0.75)">Four ways Sula Café elevates your event — pick one, mix several, build a complete experience.</p>
			</div>
			<div class="menu-grid">
				<div class="menu-card reveal">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/masala-chai-sula-indian-restaurant.webp" alt="Live masala chai station catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">The Heart of the Event</span>
					<h3>Live <em>Chai Bar</em></h3>
					<p>Masala chai brewed fresh on-site in copper urns. Cardamom, ginger, fennel — spiced to your taste. Adrak chai, kahwa, kashmiri pink chai available too.</p>
				</div>
				<div class="menu-card reveal delay-100">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/best-coctail-bar-vancouver.webp" alt="Specialty coffee catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Specialty Espresso Bar</span>
					<h3>Coffee <em>Service</em></h3>
					<p>Espresso, cortados, lattes, drip — full barista service from our café team. Single-origin beans, plant-based milks, syrup options.</p>
				</div>
				<div class="menu-card reveal delay-200">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/desserts-vancouver.webp" alt="Indian bakery catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Fresh-Baked Daily</span>
					<h3>Bakery <em>& Pastries</em></h3>
					<p>Buttery croissants, masala biscuits, koliyada, Indian sweets, and seasonal cakes — baked fresh and delivered the morning of your event.</p>
				</div>
				<div class="menu-card reveal delay-300">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-street-food-near-me.webp" alt="Indian street food catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Mumbai's Street Corner</span>
					<h3>Street <em>Food</em></h3>
					<p>Pav bhaji, vada pav, Mumbai sandwich, dabeli, kachori — live stations with full Bombay-style street energy.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ONE CUP, ONE CONNECTION - alt-row PLUM -->
	<section class="section section-plum">
		<div class="container">
			<div class="experience">
				<div class="experience-img reveal-left">
					<img src="https://sulacafe.com/wp-content/uploads/2026/02/sula-cafe-near-me-vancouver.webp" alt="Sula Cafe Vancouver chai" loading="lazy" />
				</div>
				<div class="experience-content reveal-right">
					<p class="gold-label">One Cup. One Connection.</p>
					<h2>Where Mornings <em>Begin</em><br/>and Conversations <em>Linger</em></h2>
					<p>A cup of chai is never just a cup of chai. It's an invitation. It's the pause between rush hours. It's the moment a morning becomes a memory. Sula Café was built around that idea — and we bring the same philosophy to every event we cater.</p>
					<p>Whether it's a 7AM team kickoff, a wedding morning chai ritual, or a late-night dessert and coffee bar at a reception, we don't just serve drinks. We serve the kind of warmth that makes a room feel like a second home.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- IMAGE BANNER -->
	<div class="image-banner" style="background-image: url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-street-food-near-me.webp');">
		<div class="image-banner-content reveal">
			<h2>Live Stations.<br/><em>Honest Flavours.</em></h2>
			<p>Bombay street food, brewed fresh, served with the warmth of home.</p>
		</div>
	</div>

	<!-- PERFECT FOR - cream decorated intro -->
	<section class="section section-cream">
		<div class="container-narrow">
			<div class="text-center reveal">
				<p class="eyebrow">When to Book Café Catering</p>
				<h2 class="mag-title">Perfect <em>For</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<div class="pull-quote">
					<p class="pull-quote-text">Office breakfasts. Wedding morning chai rituals. Sangeet pre-dinner stations. Reception coffee &amp; dessert bars. Diwali brunches. Private dinners that need a perfect ending. Conferences with all-day chai service. Anywhere people gather — and need to feel <em>cared for</em>.</p>
					<p class="pull-quote-attribution">— The Sula Café Team</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="cta-section">
		<div class="reveal">
			<p class="gold-label" style="color:var(--gold-light)">Bring the Café to Your Event</p>
			<h2>Pour the <em>First Cup</em></h2>
			<p>Tell us your event details. We'll send you a custom café catering quote within 24 hours.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request a Quote</a>
		</div>
	</section>

</Layout>
