---
import Layout from '../layouts/Layout.astro';
---
<Layout
	title="Corporate Catering Vancouver | Office Lunch Catering | Sula Catering"
	description="Reliable Indian corporate catering in Vancouver since 2010. Office lunches, board meetings, conferences, and corporate events. Halal, vegetarian, vegan options. Same-day delivery available."
	canonical="/corporate"
	ogImage="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-burnaby-richmond-for-corporate-offices-private-parties-and-weddings.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Service",
			"name": "Corporate Catering Vancouver",
			"provider": {"@id": "https://sulacatering.com/#organization"},
			"areaServed": ["Vancouver", "Burnaby", "Richmond", "Surrey", "North Vancouver"],
			"serviceType": "Corporate Catering",
			"description": "Reliable Indian corporate catering for Vancouver offices — board meetings, conferences, team lunches, and corporate events with halal, vegetarian, and vegan options."
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{"@type":"Question","name":"How much notice do you need for office catering?","acceptedAnswer":{"@type":"Answer","text":"Standard orders require 48 hours notice. Same-day catering may be available depending on guest count and menu — contact us directly for urgent requests."}},
				{"@type":"Question","name":"Do you deliver hot food to offices?","acceptedAnswer":{"@type":"Answer","text":"Yes — all hot dishes are delivered in temperature-controlled containers to maintain freshness and food-safe temperatures from kitchen to office."}},
				{"@type":"Question","name":"Can you accommodate dietary restrictions?","acceptedAnswer":{"@type":"Answer","text":"Yes — we offer halal-certified, vegetarian, vegan, gluten-free, and Jain menus. Allergens are clearly labelled on every order."}},
				{"@type":"Question","name":"Do you offer recurring office lunch programs?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Many Vancouver companies use Sula for weekly or monthly team lunches. We can build a rotating menu to keep things fresh."}}
			]
		})} />
	</Fragment>

	<!-- HERO -->
	<section class="hero" style="background-image: linear-gradient(135deg, rgba(10,22,40,0.85) 0%, rgba(28,47,84,0.6) 50%, rgba(10,22,40,0.85) 100%), url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-burnaby-richmond-for-corporate-offices-private-parties-and-weddings.webp');">
		<div class="hero-content">
			<p class="gold-label">Corporate Catering</p>
			<h1>Office Catering<br/>That <em>Performs</em></h1>
			<p class="hero-tagline">Reliable. Punctual. Beautifully presented. Trusted by Vancouver's leading companies for over fifteen years.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request Office Catering</a>
		</div>
	</section>

	<!-- INTRO -->
	<section class="section section-cream">
		<div class="container">
			<div class="intro-block reveal">
				<p class="gold-label">Trusted by Vancouver's Best</p>
				<h2>Catering Built for <em>Business</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<p>Boardroom lunches. Conference catering. All-hands meetings. Client events. Fifteen years of perfecting the discipline of corporate catering — arriving on time, every time, with food that elevates the meeting and respects every dietary need.</p>
			</div>
		</div>
	</section>

	<!-- FULL-WIDTH IMAGE -->
	<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/office-catering-vancouver-bc.webp" alt="Office catering Vancouver BC" class="full-width-image" loading="lazy" />

	<!-- SERVICES MENU CARDS -->
	<section class="section section-cream">
		<div class="container-narrow">
			<div class="text-center reveal">
				<p class="eyebrow">Our Corporate Services</p>
				<h2 class="mag-title">Built for <em>Every Meeting</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<p style="max-width:680px;margin:0 auto;font-size:16px;color:rgba(26,26,26,0.75)">Whatever the occasion, we have a format that fits.</p>
			</div>
			<div class="menu-grid">
				<div class="menu-card reveal">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/Indian-food-catering-vancouver-bc-canada.webp" alt="Boardroom lunch catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Daily Office Lunches</span>
					<h3>Boardroom <em>Lunches</em></h3>
					<p>Individually packed meals or buffets. Perfect for team meetings and client lunches.</p>
				</div>
				<div class="menu-card reveal delay-100">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-near-me-vancouver.webp" alt="Conference catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Large-Scale Events</span>
					<h3>Conferences <em>& Summits</em></h3>
					<p>Multi-day catering. Continental breakfast, hot lunch, snacks and refreshments.</p>
				</div>
				<div class="menu-card reveal delay-200">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/office-catering-vancouver-bc.webp" alt="Holiday office party catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Year-End Celebrations</span>
					<h3>Holiday <em>Parties</em></h3>
					<p>End-of-year celebrations. Hot buffets, live stations, full bar pairing options.</p>
				</div>
				<div class="menu-card reveal delay-300">
					<div class="menu-card-img">
						<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-burnaby-richmond-for-corporate-offices-private-parties-and-weddings.webp" alt="Client entertaining catering Vancouver" loading="lazy" />
					</div>
					<span class="eyebrow">Hospitality That Closes</span>
					<h3>Client <em>Entertaining</em></h3>
					<p>Premium plated dinners and curated experiences for high-stakes meetings.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- WHY SULA - alt-row in DARK section -->
	<section class="section section-dark">
		<div class="container">
			<div class="experience">
				<div class="experience-img reveal-left">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/Indian-food-catering-vancouver-burnaby-richmond.webp" alt="Indian food catering Vancouver Burnaby Richmond" loading="lazy" />
				</div>
				<div class="experience-content reveal-right">
					<p class="gold-label">Why Vancouver Companies Choose Sula</p>
					<h2>Punctual. <em>Polished.</em><br/>Predictably <em>Excellent.</em></h2>
					<p>Corporate catering lives or dies by reliability. Late delivery, lukewarm food, missing dietary options — these aren't inconveniences, they're meeting failures. Our coordinators treat every office order with the same precision we bring to a 400-guest wedding.</p>
					<p>That's why over a hundred Vancouver companies trust Sula for their team lunches, board meetings, and client entertaining.</p>
					<div class="experience-stats">
						<div class="stat-item">
							<div class="stat-number">100+</div>
							<div class="stat-label">Companies</div>
						</div>
						<div class="stat-item">
							<div class="stat-number">48hr</div>
							<div class="stat-label">Lead Time</div>
						</div>
						<div class="stat-item">
							<div class="stat-number">100%</div>
							<div class="stat-label">On Time</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- IMAGE BANNER -->
	<div class="image-banner" style="background-image: url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-near-me-vancouver.webp');">
		<div class="image-banner-content reveal">
			<h2>Hot Food. <em>On Time.</em><br/>Every Time.</h2>
			<p>Temperature-controlled delivery across the Lower Mainland.</p>
		</div>
	</div>

	<!-- HOW WE WORK - numbered list (PLUM) -->
	<section class="section section-plum">
		<div class="container-narrow">
			<div class="text-center reveal">
				<p class="eyebrow">How It Works</p>
				<h2 class="mag-title">From Inquiry to <em>Delivery</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="numbered-list">
				<div class="numbered-item reveal">
					<div class="numbered-num">01</div>
					<div class="numbered-content">
						<h3><em>Reach Out</em></h3>
						<p>Send us your guest count, date, dietary requirements, and any preferences. We respond within hours.</p>
					</div>
				</div>
				<div class="numbered-item reveal">
					<div class="numbered-num">02</div>
					<div class="numbered-content">
						<h3>Customise <em>the Menu</em></h3>
						<p>We'll suggest a menu, adjust based on your feedback, and confirm pricing. Tastings available for recurring programs.</p>
					</div>
				</div>
				<div class="numbered-item reveal">
					<div class="numbered-num">03</div>
					<div class="numbered-content">
						<h3>Delivered <em>& Set Up</em></h3>
						<p>We arrive on time, set up the buffet or distribute individual meals, and clean up after. You focus on the meeting.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- TESTIMONIAL (cream) -->
	<section class="section section-cream">
		<div class="container">
			<div class="testimonial-block reveal">
				<p class="gold-label" style="color:var(--gold)">Trusted by Vancouver's Companies</p>
				<p class="testimonial-quote" style="color:var(--midnight)">We've used Sula for our team lunches every other week for two years. They've never been late. They've never missed a dietary need. And the food is always — always — outstanding.</p>
				<p class="testimonial-author">— Office Manager · Vancouver Tech Company</p>
			</div>
		</div>
	</section>

	<!-- FAQ (dark section) -->
	<section class="section section-dark">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Common Questions</p>
				<h2 class="mag-title">Corporate <em>FAQs</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="faq-list">
				<div class="faq-item reveal"><h3>How much notice do you need?</h3><p>Standard orders require 48 hours notice. Same-day catering may be available depending on guest count and menu.</p></div>
				<div class="faq-item reveal"><h3>Do you deliver hot food to offices?</h3><p>Yes — all hot dishes are delivered in temperature-controlled containers to maintain freshness and food-safe temperatures.</p></div>
				<div class="faq-item reveal"><h3>Can you accommodate dietary restrictions?</h3><p>Yes — halal-certified, vegetarian, vegan, gluten-free, and Jain menus. Allergens are clearly labelled.</p></div>
				<div class="faq-item reveal"><h3>Do you offer recurring office lunch programs?</h3><p>Absolutely. Many Vancouver companies use Sula for weekly or monthly team lunches with rotating menus.</p></div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="cta-section">
		<div class="reveal">
			<p class="gold-label" style="color:var(--gold-light)">Begin the Conversation</p>
			<h2>Let's Cater Your <em>Next Event</em></h2>
			<p>Tell us about your office, your timeline, and your team. We'll respond within hours.</p>
			<a href="https://sulaindianrestaurant.com/request-a-quote/" class="btn btn-gold">Request a Quote</a>
		</div>
	</section>

</Layout>
