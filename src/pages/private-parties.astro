---
import Layout from '../layouts/Layout.astro';
---
<Layout
	title="Private Party Catering Vancouver | Birthdays, Anniversaries, Celebrations | Sula"
	description="Indian catering for birthdays, anniversaries, housewarmings, and private parties in Vancouver. Custom menus, halal options, vegan and vegetarian dishes. Lower Mainland delivery."
	canonical="/private-parties"
	ogImage="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-for-private-parties-birthdays-celebrations.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Service",
			"name": "Private Party Indian Catering Vancouver",
			"provider": { "@id": "https://sulacatering.com/#organization" },
			"areaServed": ["Vancouver", "Burnaby", "Richmond", "Surrey", "North Vancouver"],
			"serviceType": "Private Party Catering",
			"description": "Indian catering for private parties in Vancouver — birthdays, anniversaries, housewarmings, and milestone celebrations."
		})} />
	</Fragment>

	<section class="hero" style="background-image: linear-gradient(135deg, rgba(20,8,16,0.85) 0%, rgba(38,14,38,0.7) 50%, rgba(20,8,16,0.9) 100%), url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-for-private-parties-birthdays-celebrations.webp');">
		<div class="hero-content">
			<p class="gold-label">Private Party Catering</p>
			<h1>Private Parties &<br/><em>Celebrations</em></h1>
			<p class="hero-tagline">Birthdays, anniversaries, milestone moments — vibrant Indian feasts that bring your guests together around the table.</p>
			<a href="/contact" class="btn btn-gold">Request a Quote</a>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="intro-block reveal">
				<p class="gold-label">Celebrate with Flavour</p>
				<h2>Memorable Meals for <em>Every Occasion</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<p>From cozy living-room birthdays to backyard summer parties and milestone anniversaries, Sula delivers full Indian feasts tailored to your guest count and taste. Pair with chai stations from Sula Café for an unforgettable experience that keeps your guests talking long after the last plate is cleared.</p>
			</div>
		</div>
	</section>

	<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-near-me-vancouver-birthdays-parties.webp" alt="Indian catering for birthdays and parties Vancouver" class="full-width-image" loading="lazy" />

	<section class="section section-dark">
		<div class="container">
			<div class="alt-row">
				<div class="alt-row-img reveal-left">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-for-private-parties-birthdays-celebrations.webp" alt="Birthday party catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-right">
					<p class="gold-label">Birthday Parties</p>
					<h2>Milestones <em>Worth Marking</em></h2>
					<p>From kids' birthdays with crowd-pleasing samosa platters to milestone fortieths and surprise sixtieths, we tailor menus to your guest count and your guests' tastes. Butter chicken, biryani, paneer tikka — the classics, perfected.</p>
				</div>
			</div>

			<div class="alt-row reverse">
				<div class="alt-row-img reveal-right">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-near-me-vancouver.webp" alt="Anniversary dinner catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-left">
					<p class="gold-label">Anniversaries</p>
					<h2>Intimate Dinners, <em>Elegant Plating</em></h2>
					<p>Plated dinners or family-style buffets with refined presentation. For anniversaries that deserve more than a restaurant reservation — bring the celebration home, and let us handle the rest.</p>
				</div>
			</div>

			<div class="alt-row">
				<div class="alt-row-img reveal-left">
					<img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/Indian-food-catering-vancouver-bc-canada.webp" alt="Housewarming catering Vancouver" loading="lazy" />
				</div>
				<div class="alt-row-content reveal-right">
					<p class="gold-label">Housewarmings</p>
					<h2>New Beginnings, <em>Old Traditions</em></h2>
					<p>Finger food packages, samosa platters, and live chaat stations — perfect for housewarmings, religious gatherings, and holiday parties. Easy to serve, even easier to love.</p>
				</div>
			</div>
		</div>
	</section>

	<div class="image-banner" style="background-image: url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-vancouver.webp');">
		<div class="image-banner-content reveal">
			<h2>Holiday Gatherings, <em>Reimagined</em></h2>
			<p>Diwali, Christmas, New Year — themed menus for moments that matter.</p>
		</div>
	</div>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="gold-label">Flexible Service</p>
				<h2 style="font-size:42px;font-weight:400">Drop-Off, Buffet, or <em style="color:var(--gold)">Full-Service</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
				<p style="font-size:17px;max-width:780px;margin:0 auto;color:rgba(50,34,28,0.8)">For smaller parties, our drop-off catering keeps things simple. For larger events, choose buffet setup or full-service catering with our team handling everything from setup to cleanup.</p>
			</div>
			<div class="services-grid">
				<div class="service-card reveal">
					<h3>Drop-Off Catering</h3>
					<p>Hot trays delivered ready to serve. Perfect for casual gatherings of 10–30 guests.</p>
				</div>
				<div class="service-card reveal delay-100">
					<h3>Buffet Service</h3>
					<p>Full buffet setup with chafing dishes and labels. Crowd favourite for parties of 30+.</p>
				</div>
				<div class="service-card reveal delay-200">
					<h3>Plated Dinner</h3>
					<p>Individual plates for elegant anniversaries and intimate sit-down celebrations.</p>
				</div>
				<div class="service-card reveal delay-300">
					<h3>Live Stations</h3>
					<p>Chaat counters, dosa stations, and chai bars for an interactive experience.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-dark">
		<div class="container">
			<div class="testimonial-block reveal">
				<p class="gold-label">From Our Hosts</p>
				<p class="testimonial-quote">My mom turned 70 and Sula made the entire night. The food was incredible, the setup was beautiful, and the team handled everything. I just got to enjoy the party with my family.</p>
				<p class="testimonial-author">— Meera · 70th Birthday Celebration</p>
			</div>
		</div>
	</section>

	<section class="cta-section">
		<div class="reveal">
			<p class="gold-label" style="color:var(--gold-light)">Begin the Conversation</p>
			<h2>Plan Your <em>Celebration</em></h2>
			<p>Tell us about your event. We'll respond within 24 hours with a custom menu and quote.</p>
			<a href="/contact" class="btn btn-gold">Request a Quote</a>
		</div>
	</section>

</Layout>
