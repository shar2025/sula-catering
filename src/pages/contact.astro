---
import Layout from '../layouts/Layout.astro';
import TrustedBy from '../components/TrustedBy.astro';
---
<Layout
	title="Contact Sula Catering Vancouver | Request a Quote"
	description="Contact Sula Catering Vancouver for wedding, corporate, and private party catering. Email, phone, or request a quote online. Response within 24 hours."
	canonical="/contact"
	ogImage="https://sulacatering.com/uploads/best-caterer-vancouver.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org","@type": "ContactPage",
			"name": "Contact Sula Catering Vancouver",
			"author": {"@id": "https://sulacatering.com/#organization"}
		})} />
	</Fragment>

	<section class="hero" style="min-height:55vh;background-image: linear-gradient(135deg, rgba(20,8,16,0.85) 0%, rgba(38,14,38,0.7) 50%, rgba(20,8,16,0.9) 100%), url('/uploads/Indian-food-catering-vancouver-burnaby-richmond-office.webp');">
		<div class="hero-content">
			<h1>Let's Plan<br/><em>Together</em></h1>
			<p class="hero-tagline">Tell us about your event. We'll respond within 24 hours with a custom menu and quote.</p>
		</div>
	</section>

	<TrustedBy />


	<section class="section section-cream">
		<div class="container">
			<div class="intro-block reveal">
				<h2>Reach <em>Out</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p>Whether you're booking <a href="/weddings" class="body-link">wedding catering</a>, planning <a href="/corporate" class="body-link">corporate catering</a>, organising a <a href="/private-parties" class="body-link">private party</a>, or adding <a href="/cafe-catering" class="body-link">café catering</a> to an event, we'd love to hear from you. Most quotes go out within hours.</p>
			</div>
			<div class="contact-cards">
				<div class="contact-card reveal">
					<div class="icon">✉</div>
					<h3>Email</h3>
					<p>For detailed quotes, menus, and availability.</p>
					<a href="mailto:events@sulaindianrestaurant.com">events@sulaindianrestaurant.com</a>
				</div>
				<div class="contact-card reveal delay-100">
					<div class="icon">☏</div>
					<h3>Phone</h3>
					<p>Call our catering team directly, fastest for urgent timelines.</p>
					<a href="tel:6042151130">604-215-1130</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-dark pattern-mandala">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Visit Sula</p>
				<h2 class="mag-title">Our <em>Locations</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p style="max-width:680px;margin:0 auto;font-size:16px">Four Vancouver locations, three full-service restaurants and our café in East Van.</p>
			</div>
			<div class="locations-grid">
				<div class="location-card reveal">
					<h3>Commercial Drive</h3>
					<p class="addr">1128 Commercial Drive<br/>Vancouver, BC</p>
					<a href="tel:6042151130" class="phone">604-215-1130</a>
				</div>
				<div class="location-card reveal delay-100">
					<h3>Davie Street</h3>
					<p class="addr">1708 Davie Street<br/>Vancouver, BC</p>
					<a href="tel:6044284400" class="phone">604-428-4400</a>
				</div>
				<div class="location-card reveal delay-200">
					<h3>Main Street</h3>
					<p class="addr">4172 Main Street<br/>Vancouver, BC</p>
					<a href="tel:6048745375" class="phone">604-874-5375</a>
				</div>
				<div class="location-card reveal delay-300">
					<h3>Sula Café</h3>
					<p class="addr">260 East 5th Ave<br/>Vancouver, BC</p>
					<a href="tel:7783861130" class="phone">778-386-1130</a>
				</div>
			</div>
		</div>
	</section>


</Layout>
