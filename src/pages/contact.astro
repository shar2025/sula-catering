---
import Layout from '../layouts/Layout.astro';
---
<Layout
	title="Get a Catering Quote | Sula Catering Vancouver"
	description="Request an Indian catering quote for your wedding, corporate event, or private party in Vancouver. We respond within 24 hours."
	canonical="/contact"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ContactPage",
			"name": "Contact Sula Catering Vancouver",
			"url": "https://sulacatering.com/contact",
			"description": "Request a catering quote from Sula Catering Vancouver. Phone, email, and online form."
		})} />
	</Fragment>

	<section class="hero" style="min-height: 60vh; background-image: linear-gradient(135deg, rgba(20,8,16,0.85) 0%, rgba(38,14,38,0.7) 50%, rgba(20,8,16,0.9) 100%), url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-vancouver.webp');">
		<div class="hero-content">
			<p class="gold-label">Get in Touch</p>
			<h1>Request a <em>Catering Quote</em></h1>
			<p class="hero-tagline">Tell us about your event. We'll respond within 24 hours with a custom menu and quote.</p>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; max-width: 1100px; margin: 0 auto;" class="contact-grid">

				<div class="reveal-left">
					<p class="gold-label">Contact Sula Catering</p>
					<h2 style="font-size:36px;font-weight:400;margin-bottom:24px">Let's Plan Your <em style="color:var(--gold)">Event</em></h2>
					<div class="gold-divider-ornament" style="justify-content:flex-start;margin-left:0">
						<span></span><div class="diamond"></div><span></span>
					</div>

					<p style="font-size:16px;margin-bottom:40px;line-height:1.9">Whether it's a wedding for 500, an office lunch for 20, or a chai bar for a private party — we'll build a menu that fits your event perfectly.</p>

					<div style="margin-bottom:32px">
						<h3 style="font-size:13px;color:var(--gold);text-transform:uppercase;letter-spacing:3px;margin-bottom:8px;font-family:'Montserrat',sans-serif;font-weight:500">Phone</h3>
						<p style="font-size:18px;font-family:'Cormorant Garamond',serif;color:var(--plum)">604-215-1130</p>
					</div>

					<div style="margin-bottom:32px">
						<h3 style="font-size:13px;color:var(--gold);text-transform:uppercase;letter-spacing:3px;margin-bottom:8px;font-family:'Montserrat',sans-serif;font-weight:500">Email</h3>
						<p style="font-size:18px;font-family:'Cormorant Garamond',serif;color:var(--plum)">catering@sulaindianrestaurant.com</p>
					</div>

					<div style="margin-bottom:32px">
						<h3 style="font-size:13px;color:var(--gold);text-transform:uppercase;letter-spacing:3px;margin-bottom:8px;font-family:'Montserrat',sans-serif;font-weight:500">Service Areas</h3>
						<p style="font-size:15px">Vancouver · Burnaby · Richmond<br/>Surrey · North Vancouver · West Vancouver</p>
					</div>

					<div>
						<h3 style="font-size:13px;color:var(--gold);text-transform:uppercase;letter-spacing:3px;margin-bottom:16px;font-family:'Montserrat',sans-serif;font-weight:500">Visit Sula</h3>
						<p style="font-size:14px;line-height:2"><strong style="color:var(--plum)">Sula Commercial Drive</strong><br/>1128 Commercial Drive, Vancouver</p>
						<p style="font-size:14px;line-height:2;margin-top:12px"><strong style="color:var(--plum)">Sula Davie Street</strong><br/>1708 Davie Street, Vancouver</p>
						<p style="font-size:14px;line-height:2;margin-top:12px"><strong style="color:var(--plum)">Sula Main Street</strong><br/>4172 Main Street, Vancouver</p>
						<p style="font-size:14px;line-height:2;margin-top:12px"><strong style="color:var(--plum)">Sula Café</strong><br/>260 East 5th Ave, Vancouver</p>
					</div>
				</div>

				<div class="reveal-right">
					<div style="background: linear-gradient(180deg, #fff 0%, var(--cream) 100%); padding: 48px; border-top: 2px solid var(--gold); box-shadow: 0 20px 50px rgba(38,14,38,0.08);">
						<h2 style="font-size:28px;font-weight:500;margin-bottom:8px">Quote Request Form</h2>
						<p style="font-size:14px;color:rgba(50,34,28,0.7);margin-bottom:32px;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:16px">Fill in the form below — we'll be in touch within 24 hours.</p>

						<!--
							REPLACE THE IFRAME BELOW WITH YOUR GRAVITY FORM EMBED.
							Get the embed URL from your WordPress admin → your form → embed shortcode.
						-->
						<iframe
							src="https://sulaindianrestaurant.com/request-a-quote/?embed=1"
							width="100%"
							height="650"
							frameborder="0"
							style="border: none;"
							title="Catering Quote Request Form">
						</iframe>

						<p style="font-size:13px;color:rgba(50,34,28,0.6);margin-top:20px;text-align:center">Form not loading? Email us directly at <a href="mailto:catering@sulaindianrestaurant.com">catering@sulaindianrestaurant.com</a></p>
					</div>
				</div>

			</div>
		</div>
	</section>

	<style>
		@media (max-width: 900px) {
			.contact-grid {
				grid-template-columns: 1fr !important;
				gap: 60px !important;
			}
		}
	</style>

</Layout>
