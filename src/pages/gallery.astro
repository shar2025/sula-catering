---
import Layout from '../layouts/Layout.astro';
---
<Layout
	title="Catering Gallery | Sula Catering Vancouver — Wedding & Event Photos"
	description="Photo gallery of Indian catering events in Vancouver — weddings, corporate lunches, private parties, chai bars, and more from Sula Catering."
	canonical="/gallery"
	ogImage="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/Indian-food-catering-vancouver-burnaby-richmond.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "ImageGallery",
			"name": "Sula Catering Vancouver Gallery",
			"description": "Photo gallery of Indian catering events in Vancouver — weddings, corporate, private parties.",
			"url": "https://sulacatering.com/gallery"
		})} />
	</Fragment>

	<section class="hero" style="min-height: 60vh; background-image: linear-gradient(135deg, rgba(20,8,16,0.85) 0%, rgba(38,14,38,0.7) 50%, rgba(20,8,16,0.9) 100%), url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/Indian-food-catering-vancouver-burnaby-richmond.webp');">
		<div class="hero-content">
			<p class="gold-label">Recent Events</p>
			<h1>Catering <em>Gallery</em></h1>
			<p class="hero-tagline">A look at recent weddings, corporate events, and celebrations across the Lower Mainland.</p>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="gold-label">Weddings</p>
				<h2 style="font-size:42px;font-weight:400">Vancouver <em style="color:var(--gold)">Weddings</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="gallery-grid-2">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddinf-catering-vancouver-bc.webp" alt="Wedding catering Vancouver BC" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddin-catering-burnaby-vancouver.webp" alt="Wedding catering Burnaby Vancouver" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="section section-dark">
		<div class="container">
			<div class="text-center reveal">
				<p class="gold-label">Corporate & Office</p>
				<h2 style="font-size:42px;font-weight:400">Office <em>Catering</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="gallery-grid-3">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/office-catering-vancouver-bc.webp" alt="Office catering Vancouver BC" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/Indian-food-catering-vancouver-burnaby-richmond.webp" alt="Indian food catering Vancouver Burnaby Richmond" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/Indian-food-catering-vancouver-bc-canada.webp" alt="Indian food catering Vancouver BC Canada" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="gold-label">Private Parties</p>
				<h2 style="font-size:42px;font-weight:400">Birthdays & <em style="color:var(--gold)">Celebrations</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="gallery-grid-3">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-for-private-parties-birthdays-celebrations.webp" alt="Indian catering Vancouver private parties birthdays" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-near-me-vancouver-birthdays-parties.webp" alt="Indian catering near me Vancouver birthdays parties" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-food-catering-near-me-vancouver-bc.webp" alt="Indian food catering near me Vancouver BC" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="section section-dark">
		<div class="container">
			<div class="text-center reveal">
				<p class="gold-label">Food & Drink</p>
				<h2 style="font-size:42px;font-weight:400">The <em>Flavours</em></h2>
				<div class="gold-divider-ornament">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="gallery-grid">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/best-chicken-tikka-masala-vancouver.webp" alt="Best chicken tikka masala Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-street-food-near-me.webp" alt="Indian street food near me" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/desserts-vancouver.webp" alt="Indian desserts Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-300"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/masala-chai-sula-indian-restaurant.webp" alt="Masala chai Sula Indian Restaurant" loading="lazy" /></div>
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-food-dishes-vancouver.webp" alt="Indian food dishes Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/cocktail-bar-vancouver.webp" alt="Cocktail bar Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/best-coctail-bar-vancouver.webp" alt="Best cocktail bar Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-300"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/02/Mumbai-vada.webp" alt="Mumbai vada Sula" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="cta-section">
		<div class="reveal">
			<p class="gold-label" style="color:var(--gold-light)">Like What You See?</p>
			<h2>Let's Plan <em>Yours</em></h2>
			<p>Tell us about your event. We'll respond within 24 hours with a custom menu and quote.</p>
			<a href="/contact" class="btn btn-gold">Request a Quote</a>
		</div>
	</section>

</Layout>
