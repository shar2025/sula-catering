---
import Layout from '../layouts/Layout.astro';
import TrustedBy from '../components/TrustedBy.astro';
---
<Layout
	title="Catering Gallery Vancouver | Sula Indian Catering Photo Gallery"
	description="A visual journey through Sula's wedding catering, corporate catering, private party, and café catering across Vancouver. Real events, beautifully photographed."
	canonical="/gallery"
	ogImage="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddinf-catering-vancouver-bc.webp"
>

	<Fragment slot="schema">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org","@type": "ImageGallery",
			"name": "Sula Catering Vancouver Gallery",
			"author": {"@id": "https://sulacatering.com/#organization"}
		})} />
	</Fragment>

	<section class="hero" style="min-height:60vh;background-image: linear-gradient(135deg, rgba(5,11,21,0.7) 0%, rgba(20,36,66,0.5) 50%, rgba(37,4,45,0.7) 100%), url('https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddinf-catering-vancouver-bc.webp');">
		<div class="hero-content">
			<h1>Moments,<br/><em>Captured</em></h1>
			<p class="hero-tagline">A visual journey through fifteen years of weddings, celebrations, and quiet moments worth remembering.</p>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Section One</p>
				<h2 class="mag-title">Weddings &amp; <em>Receptions</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p style="max-width:680px;margin:0 auto 16px;font-size:16px;color:rgba(26,26,26,0.75)">From sangeet to reception. Explore our <a href="/weddings" class="body-link">wedding catering services</a>.</p>
			</div>
			<div class="gallery-grid-2">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/01/WEDDING.jpg" alt="Indian wedding catering Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddinf-catering-vancouver-bc.webp" alt="Wedding catering Vancouver BC" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/weddin-catering-burnaby-vancouver.webp" alt="Wedding catering Burnaby Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-300"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/Indian-food-catering-vancouver-burnaby-richmond.webp" alt="Indian food catering Vancouver Burnaby Richmond" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="section section-plum">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Section Two</p>
				<h2 class="mag-title">Corporate &amp; <em>Office</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p style="max-width:680px;margin:0 auto 16px;font-size:16px;color:rgba(245,237,224,0.85)">Boardroom lunches and conferences. See our <a href="/corporate" class="body-link">corporate catering services</a>.</p>
			</div>
			<div class="gallery-grid-3">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/office-catering-vancouver-bc.webp" alt="Office catering Vancouver BC" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-burnaby-richmond-for-corporate-offices-private-parties-and-weddings.webp" alt="Corporate Indian catering Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/Indian-food-catering-vancouver-bc-canada.webp" alt="Indian food catering Vancouver BC Canada" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="section section-cream">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Section Three</p>
				<h2 class="mag-title">Private &amp; <em>Personal</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p style="max-width:680px;margin:0 auto 16px;font-size:16px;color:rgba(26,26,26,0.75)">Birthdays, anniversaries, Diwali, explore <a href="/private-parties" class="body-link">private party catering</a>.</p>
			</div>
			<div class="gallery-grid-3">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-catering-near-me-vancouver-birthdays-parties.webp" alt="Birthday party catering Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-catering-vancouver-for-private-parties-birthdays-celebrations.webp" alt="Indian catering private parties Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/04/indian-food-catering-near-me-vancouver-bc.webp" alt="Indian food catering Vancouver BC" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<section class="section section-dark">
		<div class="container">
			<div class="text-center reveal">
				<p class="eyebrow">Section Four</p>
				<h2 class="mag-title">Food &amp; <em>Drink</em></h2>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
				<p style="max-width:680px;margin:0 auto 16px;font-size:16px;color:rgba(245,237,224,0.85)">Close-ups of butter chicken, biryani, masala chai. See our <a href="/cafe-catering" class="body-link">café catering menu</a>.</p>
			</div>
			<div class="gallery-grid">
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/best-chicken-tikka-masala-vancouver.webp" alt="Best chicken tikka masala Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-street-food-near-me.webp" alt="Indian street food Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/desserts-vancouver.webp" alt="Indian desserts Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-300"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/masala-chai-sula-indian-restaurant.webp" alt="Masala chai Sula Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/indian-food-dishes-vancouver.webp" alt="Indian food dishes Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-100"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/cocktail-bar-vancouver.webp" alt="Cocktail bar Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-200"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/best-coctail-bar-vancouver.webp" alt="Best cocktail bar Vancouver" loading="lazy" /></div>
				<div class="gallery-item reveal-scale delay-300"><img src="https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/02/Mumbai-vada.webp" alt="Mumbai vada Vancouver" loading="lazy" /></div>
			</div>
		</div>
	</section>

	<TrustedBy />

	<section class="cta-section cta-plum">
		<div class="reveal">
			<h2>Let's Add Your Event to <em>the Gallery</em></h2>
			<p>Tell us about your celebration, we'll bring the same care to your event.</p>
			<a href="https://sulaindianrestaurant.com/sula-catering/" class="btn btn-gold">Request a Quote</a>
		</div>
	</section>

</Layout>
