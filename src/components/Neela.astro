	/* ORDER SUMMARY CARD, renders below Neela's bubble when she emits the order marker */
	.neela-order-card{align-self:stretch;margin:4px 4px 8px;padding:18px 20px;background:linear-gradient(135deg,rgba(20,36,66,0.55),rgba(37,4,45,0.35));border:1px solid var(--gold);border-radius:14px;box-shadow:0 0 0 1px rgba(232,201,135,0.08),0 8px 22px rgba(10,22,40,0.32);animation:neela-fade-up 0.45s cubic-bezier(0.4,0,0.2,1) both;position:relative}
