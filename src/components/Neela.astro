	.neela-tier-cards{display:flex;flex-direction:column;gap:10px;align-self:stretch;margin:6px 4px 10px;animation:neela-fade-up 0.35s cubic-bezier(0.4,0,0.2,1) both}
	.neela-tier-card{min-height:72px;padding:14px 16px;background:linear-gradient(135deg,rgba(20,36,66,0.65),rgba(37,4,45,0.4));border:1px solid var(--gold);border-radius:12px;color:var(--cream);font-family:'Montserrat',sans-serif;cursor:pointer;text-align:left;display:flex;flex-direction:column;gap:6px;box-shadow:0 0 0 1px rgba(232,201,135,0.08),0 4px 12px rgba(10,22,40,0.22);transition:transform 0.25s ease,background 0.25s ease,border-color 0.25s ease,box-shadow 0.25s ease}
