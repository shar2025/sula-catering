	.neela-tiers-more{display:flex;justify-content:center;align-self:stretch;margin:-2px 4px 10px;animation:neela-fade-up 0.3s cubic-bezier(0.4,0,0.2,1) both;transition:opacity 0.28s ease,max-height 0.28s ease}
	.neela-tiers-more-btn{min-height:36px;padding:8px 18px;background:rgba(20,36,66,0.45);border:1px solid rgba(184,149,106,0.55);border-radius:999px;color:var(--cream);font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:13.5px;font-weight:600;letter-spacing:0.4px;cursor:pointer;line-height:1.2;transition:transform 0.25s ease,background 0.25s ease,border-color 0.25s ease,box-shadow 0.25s ease}
	.neela-tiers-more-btn:hover,.neela-tiers-more-btn:focus-visible{background:rgba(184,149,106,0.16);border-color:var(--gold-shimmer);color:var(--gold-shimmer);transform:translateY(-1px);box-shadow:0 4px 12px rgba(184,149,106,0.22);outline:none}
	.neela-tiers-more-btn:disabled{cursor:default;opacity:0.55}
	.neela-tiers-more-collapsed{opacity:0;max-height:0;margin-top:0;margin-bottom:0;pointer-events:none}
	.neela-tier-card-revealed{animation:neela-fade-up 0.32s cubic-bezier(0.4,0,0.2,1) both}

	/* INLINE CONTACT FORM, brand-styled stack of labeled inputs + submit pill.
	   Plum surrounding container, cream text, gold border focus on each input. */
	.neela-inline-form{align-self:stretch;margin:6px 4px 10px;padding:14px 16px 16px;background:linear-gradient(135deg,rgba(37,4,45,0.45),rgba(20,36,66,0.4));border:1px solid rgba(184,149,106,0.4);border-radius:14px;display:flex;flex-direction:column;gap:10px;box-shadow:0 0 0 1px rgba(232,201,135,0.06),0 6px 16px rgba(10,22,40,0.28);animation:neela-fade-up 0.35s cubic-bezier(0.4,0,0.2,1) both}
