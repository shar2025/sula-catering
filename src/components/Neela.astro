	.neela-flag-badge{display:inline-flex;align-items:center;gap:8px;align-self:flex-start;margin:4px 4px 8px;padding:6px 12px;background:rgba(184,149,106,0.12);border:1px solid rgba(184,149,106,0.35);border-radius:999px;font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;font-size:12.5px;color:var(--gold-light);letter-spacing:0.3px;animation:neela-fade-up 0.3s cubic-bezier(0.4,0,0.2,1) both}
	.neela-flag-badge-dot{width:7px;height:7px;border-radius:50%;background:var(--gold-shimmer);box-shadow:0 0 6px rgba(232,201,135,0.6);flex-shrink:0}
