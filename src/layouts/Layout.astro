---
const {
	title = "Sula Catering Vancouver | Award-Winning Indian Catering for Weddings, Corporate & Events",
	description = "Vancouver's most trusted Indian catering since 2010. Wedding, corporate, and private party catering across Vancouver, Burnaby, Richmond, and Surrey. Halal, vegetarian, vegan options.",
	canonical = "/",
	ogImage = "https://sulacatering.com/uploads/vancouver-catering-weddings.webp",
	breadcrumbs = null
} = Astro.props;
const fullCanonical = `https://sulacatering.com${canonical}`;

// Auto-derive breadcrumbs from canonical path unless an override is passed.
// Last crumb intentionally omits `item` per schema.org BreadcrumbList recommendation.
function titleCase(slug) {
	return slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
let breadcrumbItems = breadcrumbs;
if (!breadcrumbItems) {
	const segments = canonical.split('/').filter(Boolean);
	if (segments.length > 0) {
		breadcrumbItems = [{ name: 'Home', url: 'https://sulacatering.com/' }];
		let acc = '';
		segments.forEach((seg, i) => {
			acc += '/' + seg;
			const isLast = i === segments.length - 1;
			const entry = { name: titleCase(seg) };
			if (!isLast) entry.url = `https://sulacatering.com${acc}`;
			breadcrumbItems.push(entry);
		});
	}
}
const breadcrumbJsonLd = breadcrumbItems && breadcrumbItems.length > 1 ? {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbItems.map((b, i) => {
		const node = { "@type": "ListItem", "position": i + 1, "name": b.name };
		if (b.url) node.item = b.url;
		return node;
	})
} : null;
