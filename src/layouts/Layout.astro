---
const {
	title = "Sula Catering Vancouver | Award-Winning Indian Catering for Weddings, Corporate & Private Events",
	description = "Vancouver's most trusted Indian catering company since 2010. Award-winning wedding, corporate, and private party catering across the Lower Mainland. Halal, vegetarian, vegan menus.",
	canonical = "/",
	ogImage = "https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/vancouver-catering-sula-indian-restaurant.webp"
} = Astro.props;
const siteUrl = "https://sulacatering.com";
const fullCanonical = `${siteUrl}${canonical}`;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="canonical" href={fullCanonical} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={fullCanonical} />
		<meta property="og:site_name" content="Sula Catering Vancouver" />
		<meta property="og:locale" content="en_CA" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="author" content="Sula Indian Restaurant" />
		<meta name="geo.region" content="CA-BC" />
		<meta name="geo.placename" content="Vancouver" />

		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Montserrat:wght@200;300;400;500;600;700&display=swap" rel="stylesheet" />

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FoodEstablishment",
			"@id": "https://sulacatering.com/#organization",
			"name": "Sula Catering Vancouver",
			"alternateName": "Sula Indian Restaurant Catering",
			"description": "Award-winning Indian catering services in Vancouver for weddings, corporate events, and private parties.",
			"url": "https://sulacatering.com",
			"telephone": "+1-604-215-1130",
			"email": "catering@sulaindianrestaurant.com",
			"priceRange": "$$-$$$",
			"servesCuisine": ["Indian", "South Asian", "North Indian", "South Indian"],
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "1128 Commercial Drive",
				"addressLocality": "Vancouver",
				"addressRegion": "BC",
				"postalCode": "V5L 3X2",
				"addressCountry": "CA"
			},
			"areaServed": [
				{ "@type": "City", "name": "Vancouver" },
				{ "@type": "City", "name": "Burnaby" },
				{ "@type": "City", "name": "Richmond" },
				{ "@type": "City", "name": "Surrey" },
				{ "@type": "City", "name": "North Vancouver" },
				{ "@type": "City", "name": "West Vancouver" }
			],
			"sameAs": [
				"https://sulaindianrestaurant.com",
				"https://www.instagram.com/sulaindianrestaurant"
			],
			"image": "https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/vancouver-catering-sula-indian-restaurant.webp"
		})} />

		<slot name="schema" />
	</head>
	<body>

		<header class="site-header">
			<div class="header-inner">
				<a href="/" class="logo" aria-label="Sula Catering Home">
					<span class="logo-main">SULA</span>
					<span class="sub">CATERING</span>
				</a>
				<nav class="main-nav" aria-label="Main navigation">
					<a href="/">Home</a>
					<a href="/weddings">Weddings</a>
					<a href="/corporate">Corporate</a>
					<a href="/private-parties">Private</a>
					<a href="/cafe-catering">Café</a>
					<a href="/gallery">Gallery</a>
					<a href="/contact" class="cta">Get a Quote</a>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-logo reveal">
				<a href="/" class="logo" aria-label="Sula Catering Home">
					<span class="logo-main" style="font-size:42px;letter-spacing:8px">SULA</span>
					<span class="sub" style="font-size:11px;letter-spacing:6px">CATERING · VANCOUVER</span>
				</a>
				<div class="gold-divider-ornament" style="margin-top:24px">
					<span></span><div class="diamond"></div><span></span>
				</div>
			</div>
			<div class="footer-inner">
				<div class="footer-col">
					<h4>Sula Catering</h4>
					<p>Award-winning Indian catering across Vancouver, Burnaby, Richmond, Surrey & North Vancouver since 2010.</p>
				</div>
				<div class="footer-col">
					<h4>Services</h4>
					<a href="/weddings">Wedding Catering</a>
					<a href="/corporate">Corporate Catering</a>
					<a href="/private-parties">Private Parties</a>
					<a href="/cafe-catering">Café & Chai Catering</a>
					<a href="/gallery">Gallery</a>
				</div>
				<div class="footer-col">
					<h4>Contact</h4>
					<p>604-215-1130<br/>catering@sulaindianrestaurant.com</p>
					<a href="/contact" class="footer-cta">Request a Quote →</a>
				</div>
				<div class="footer-col">
					<h4>Visit Sula</h4>
					<p>Commercial Drive<br/>Davie Street<br/>Main Street<br/>Sula Café</p>
				</div>
			</div>
			<div class="footer-bottom">
				<p>© 2026 Sula Indian Restaurant · All Rights Reserved</p>
			</div>
		</footer>

		<style is:global>
			:root {
				--plum: #260e26;
				--plum-deep: #140810;
				--plum-mid: #3a1a3a;
				--gold: #a68a5b;
				--gold-light: #d4b572;
				--gold-shimmer: #e8c987;
				--cream: #fff4e9;
				--cream-soft: #f5e6d3;
				--dark-text: #32221c;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { overflow-x: hidden; scroll-behavior: smooth; }
			body {
				font-family: 'Montserrat', sans-serif;
				font-weight: 300;
				color: var(--dark-text);
				background: var(--cream);
				line-height: 1.7;
				letter-spacing: 0.3px;
			}
			img { max-width: 100%; height: auto; display: block; }
			a { color: var(--gold); text-decoration: none; }

			h1, h2, h3, h4 {
				font-family: 'Cormorant Garamond', serif;
				font-weight: 400;
				color: var(--plum);
				letter-spacing: 0.5px;
			}

			/* ======= ANIMATIONS ======= */
			@keyframes fadeUp {
				from { opacity: 0; transform: translateY(40px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes fadeIn {
				from { opacity: 0; }
				to { opacity: 1; }
			}
			@keyframes slideInLeft {
				from { opacity: 0; transform: translateX(-60px); }
				to { opacity: 1; transform: translateX(0); }
			}
			@keyframes slideInRight {
				from { opacity: 0; transform: translateX(60px); }
				to { opacity: 1; transform: translateX(0); }
			}
			@keyframes goldShimmer {
				0%, 100% { box-shadow: 0 0 20px rgba(166,138,91,0.3); }
				50% { box-shadow: 0 0 40px rgba(232,201,135,0.6); }
			}
			@keyframes float {
				0%, 100% { transform: translateY(0); }
				50% { transform: translateY(-8px); }
			}
			@keyframes heroFadeIn {
				0% { opacity: 0; transform: translateY(30px); letter-spacing: 12px; }
				100% { opacity: 1; transform: translateY(0); letter-spacing: 0.5px; }
			}
			@keyframes drawLine {
				from { width: 0; opacity: 0; }
				to { width: 60px; opacity: 1; }
			}
			@keyframes diamondSpin {
				from { transform: rotate(0deg); opacity: 0; }
				to { transform: rotate(45deg); opacity: 1; }
			}

			.reveal {
				opacity: 0;
				transform: translateY(40px);
				transition: opacity 1s ease, transform 1s ease;
			}
			.reveal.visible {
				opacity: 1;
				transform: translateY(0);
			}
			.reveal-left {
				opacity: 0;
				transform: translateX(-60px);
				transition: opacity 1s ease, transform 1s ease;
			}
			.reveal-left.visible {
				opacity: 1;
				transform: translateX(0);
			}
			.reveal-right {
				opacity: 0;
				transform: translateX(60px);
				transition: opacity 1s ease, transform 1s ease;
			}
			.reveal-right.visible {
				opacity: 1;
				transform: translateX(0);
			}
			.reveal-scale {
				opacity: 0;
				transform: scale(0.95);
				transition: opacity 1s ease, transform 1s ease;
			}
			.reveal-scale.visible {
				opacity: 1;
				transform: scale(1);
			}
			.delay-100 { transition-delay: 0.1s; }
			.delay-200 { transition-delay: 0.2s; }
			.delay-300 { transition-delay: 0.3s; }
			.delay-400 { transition-delay: 0.4s; }
			.delay-500 { transition-delay: 0.5s; }

			/* ======= LUXE LABELS & DIVIDERS ======= */
			.gold-label {
				display: inline-block;
				font-family: 'Montserrat', sans-serif;
				font-size: 11px;
				letter-spacing: 6px;
				text-transform: uppercase;
				color: var(--gold);
				font-weight: 500;
				margin-bottom: 24px;
			}
			.gold-label::before, .gold-label::after {
				content: '';
				display: inline-block;
				width: 32px;
				height: 1px;
				background: var(--gold);
				vertical-align: middle;
				margin: 0 16px;
				opacity: 0.6;
			}
			.gold-divider {
				width: 60px;
				height: 1px;
				background: linear-gradient(90deg, transparent, var(--gold) 50%, transparent);
				margin: 32px auto;
				border: none;
			}
			.gold-divider-ornament {
				display: flex;
				align-items: center;
				justify-content: center;
				margin: 32px 0;
				gap: 16px;
			}
			.gold-divider-ornament span {
				height: 1px;
				width: 60px;
				background: linear-gradient(90deg, transparent, var(--gold));
			}
			.gold-divider-ornament span:last-child {
				background: linear-gradient(90deg, var(--gold), transparent);
			}
			.gold-divider-ornament .diamond {
				width: 8px;
				height: 8px;
				transform: rotate(45deg);
				flex-shrink: 0;
				background: linear-gradient(135deg, var(--gold-shimmer), var(--gold));
				transition: transform 0.4s ease;
			}
			.gold-divider-ornament:hover .diamond {
				transform: rotate(135deg) scale(1.2);
			}

			/* ======= HEADER ======= */
			.site-header {
				background: linear-gradient(180deg, var(--plum-deep) 0%, var(--plum) 100%);
				color: var(--cream);
				padding: 20px 0;
				position: sticky;
				top: 0;
				z-index: 100;
				border-bottom: 1px solid rgba(166,138,91,0.2);
				box-shadow: 0 4px 30px rgba(0,0,0,0.3);
				animation: fadeIn 0.8s ease;
			}
			.header-inner {
				max-width: 1280px;
				margin: 0 auto;
				padding: 0 32px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 16px;
			}
			.logo {
				font-family: 'Cormorant Garamond', serif;
				color: var(--cream);
				line-height: 1;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				transition: opacity 0.3s;
			}
			.logo:hover { opacity: 0.85; }
			.logo .logo-main {
				font-size: 30px;
				font-weight: 500;
				letter-spacing: 6px;
			}
			.logo .sub {
				font-size: 10px;
				letter-spacing: 8px;
				color: var(--gold);
				font-style: italic;
				font-weight: 400;
				margin-top: 4px;
			}
			.main-nav {
				display: flex;
				gap: 28px;
				align-items: center;
				flex-wrap: wrap;
			}
			.main-nav a {
				color: var(--cream);
				font-size: 11px;
				font-weight: 400;
				text-transform: uppercase;
				letter-spacing: 2.5px;
				position: relative;
				padding: 6px 0;
				transition: color 0.3s;
			}
			.main-nav a::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 50%;
				width: 0;
				height: 1px;
				background: var(--gold);
				transition: all 0.4s ease;
				transform: translateX(-50%);
			}
			.main-nav a:hover { color: var(--gold); }
			.main-nav a:hover::after { width: 100%; }
			.main-nav a.cta {
				background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
				color: var(--plum);
				padding: 12px 24px;
				font-weight: 600;
				letter-spacing: 2px;
				transition: all 0.4s ease;
			}
			.main-nav a.cta::after { display: none; }
			.main-nav a.cta:hover {
				background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold-shimmer) 100%);
				color: var(--plum);
				transform: translateY(-2px);
				box-shadow: 0 8px 20px rgba(166,138,91,0.3);
			}

			/* ======= HERO ======= */
			.hero {
				position: relative;
				min-height: 90vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 80px 32px;
				color: var(--cream);
				background-size: cover;
				background-position: center;
				overflow: hidden;
				animation: fadeIn 1.2s ease;
			}
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(ellipse at center, transparent 0%, rgba(20,8,16,0.5) 100%);
			}
			.hero-content {
				position: relative;
				z-index: 2;
				max-width: 900px;
			}
			.hero .gold-label {
				color: var(--gold-light);
				animation: fadeUp 1s ease 0.3s both;
			}
			.hero h1 {
				font-size: 72px;
				color: var(--cream);
				font-weight: 300;
				line-height: 1.1;
				margin-bottom: 24px;
				font-style: italic;
				animation: fadeUp 1.2s ease 0.5s both;
			}
			.hero h1 em {
				color: var(--gold-light);
				font-style: italic;
				font-weight: 400;
			}
			.hero-tagline {
				font-size: 20px;
				font-weight: 300;
				max-width: 680px;
				margin: 0 auto 40px;
				opacity: 0.92;
				letter-spacing: 0.5px;
				font-style: italic;
				font-family: 'Cormorant Garamond', serif;
				animation: fadeUp 1.2s ease 0.8s both;
			}
			.hero .btn {
				animation: fadeUp 1.2s ease 1.1s both;
			}

			/* ======= BUTTONS ======= */
			.btn {
				display: inline-block;
				padding: 18px 40px;
				font-family: 'Montserrat', sans-serif;
				font-weight: 500;
				letter-spacing: 3px;
				text-transform: uppercase;
				font-size: 12px;
				border-radius: 0;
				transition: all 0.4s ease;
				cursor: pointer;
				border: none;
				position: relative;
				overflow: hidden;
			}
			.btn::before {
				content: '';
				position: absolute;
				top: 0; left: -100%;
				width: 100%; height: 100%;
				background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
				transition: left 0.6s ease;
			}
			.btn:hover::before { left: 100%; }
			.btn-gold {
				background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
				color: var(--plum);
				border: 1px solid var(--gold);
			}
			.btn-gold:hover {
				background: linear-gradient(135deg, var(--gold-shimmer) 0%, var(--gold-light) 100%);
				transform: translateY(-3px);
				box-shadow: 0 12px 30px rgba(166,138,91,0.5);
			}
			.btn-outline {
				background: transparent;
				color: var(--cream);
				border: 1px solid var(--gold);
			}
			.btn-outline:hover {
				background: var(--gold);
				color: var(--plum);
				transform: translateY(-3px);
			}
			.btn-plum {
				background: linear-gradient(135deg, var(--plum) 0%, var(--plum-mid) 100%);
				color: var(--cream);
				border: 1px solid var(--plum);
			}
			.btn-plum:hover {
				background: linear-gradient(135deg, var(--plum-mid) 0%, var(--plum) 100%);
				transform: translateY(-3px);
				box-shadow: 0 12px 30px rgba(38,14,38,0.4);
			}

			/* ======= SECTIONS ======= */
			.section { padding: 120px 32px; }
			.container { max-width: 1280px; margin: 0 auto; }
			.container-narrow { max-width: 1000px; margin: 0 auto; }
			.text-center { text-align: center; }
			.section-cream {
				background: linear-gradient(180deg, var(--cream) 0%, var(--cream-soft) 100%);
			}
			.section-plum {
				background: linear-gradient(135deg, var(--plum-deep) 0%, var(--plum) 50%, var(--plum-mid) 100%);
				color: var(--cream);
				position: relative;
				overflow: hidden;
			}
			.section-plum::before, .section-plum::after {
				content: '';
				position: absolute;
				left: 0;
				right: 0;
				height: 1px;
				background: linear-gradient(90deg, transparent, var(--gold), transparent);
			}
			.section-plum::before { top: 0; }
			.section-plum::after { bottom: 0; }
			.section-plum h1, .section-plum h2, .section-plum h3 { color: var(--gold-light); }
			.section-plum p { color: rgba(255,244,233,0.85); }

			/* ======= INTRO BLOCK ======= */
			.intro-block {
				text-align: center;
				max-width: 820px;
				margin: 0 auto;
			}
			.intro-block h2 {
				font-size: 48px;
				font-weight: 400;
				margin-bottom: 16px;
				line-height: 1.2;
			}
			.intro-block h2 em {
				color: var(--gold);
				font-weight: 400;
			}
			.intro-block p {
				font-size: 17px;
				line-height: 1.9;
				color: var(--dark-text);
				font-weight: 300;
			}
			.section-plum .intro-block p { color: rgba(255,244,233,0.85); }

			/* ======= SERVICE CARDS ======= */
			.services-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 32px;
				margin-top: 80px;
			}
			.service-card {
				background: linear-gradient(180deg, #fff 0%, var(--cream) 100%);
				padding: 48px 32px;
				text-align: center;
				position: relative;
				border: 1px solid rgba(166,138,91,0.2);
				transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
				color: inherit;
				display: block;
				overflow: hidden;
			}
			.service-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 50%;
				width: 0;
				height: 2px;
				background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 100%);
				transition: all 0.5s ease;
				transform: translateX(-50%);
			}
			.service-card:hover {
				transform: translateY(-12px);
				box-shadow: 0 25px 60px rgba(38,14,38,0.18);
				border-color: var(--gold);
			}
			.service-card:hover::before { width: 100%; }
			.service-card:hover .service-icon { transform: scale(1.1) rotate(5deg); }
			.service-icon {
				width: 60px;
				height: 60px;
				margin: 0 auto 24px;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: transform 0.5s ease;
			}
			.service-icon svg { width: 48px; height: 48px; stroke: var(--gold); }
			.service-card h3 { font-size: 26px; margin-bottom: 12px; font-weight: 500; }
			.service-card p {
				font-size: 14px;
				color: rgba(50,34,28,0.7);
				margin-bottom: 20px;
				line-height: 1.7;
			}
			.service-card .arrow {
				color: var(--gold);
				font-family: 'Cormorant Garamond', serif;
				font-style: italic;
				font-size: 14px;
				letter-spacing: 2px;
				text-transform: uppercase;
				font-weight: 500;
				transition: letter-spacing 0.3s;
			}
			.service-card:hover .arrow { letter-spacing: 4px; }

			/* ======= EXPERIENCE BLOCK ======= */
			.experience {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 80px;
				align-items: center;
			}
			.experience-img {
				position: relative;
				height: 600px;
				overflow: hidden;
			}
			.experience-img::before {
				content: '';
				position: absolute;
				top: 20px;
				left: 20px;
				right: -20px;
				bottom: -20px;
				border: 1px solid var(--gold);
				z-index: -1;
				transition: all 0.6s ease;
			}
			.experience-img:hover::before {
				top: 30px; left: 30px; right: -30px; bottom: -30px;
			}
			.experience-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 1s ease;
			}
			.experience-img:hover img { transform: scale(1.05); }
			.experience-content h2 {
				font-size: 48px;
				margin-bottom: 24px;
				font-weight: 400;
				line-height: 1.2;
			}
			.experience-content h2 em { color: var(--gold); font-style: italic; }
			.section-plum .experience-content h2 { color: var(--gold-light); }
			.section-plum .experience-content h2 em { color: var(--gold); }
			.experience-content p {
				font-size: 16px;
				line-height: 1.9;
				margin-bottom: 20px;
			}
			.experience-stats {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 32px;
				margin-top: 48px;
				padding-top: 40px;
				border-top: 1px solid rgba(166,138,91,0.3);
			}
			.stat-item { text-align: center; transition: transform 0.4s ease; }
			.stat-item:hover { transform: translateY(-5px); }
			.stat-number {
				font-family: 'Cormorant Garamond', serif;
				font-size: 48px;
				font-weight: 400;
				color: var(--gold-light);
				line-height: 1;
				margin-bottom: 8px;
			}
			.section-cream .stat-number { color: var(--gold); }
			.stat-label {
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 2px;
				color: var(--gold);
				font-weight: 500;
			}

			/* ======= GALLERY GRID ======= */
			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 16px;
				margin-top: 60px;
			}
			.gallery-item {
				position: relative;
				aspect-ratio: 1;
				overflow: hidden;
				cursor: pointer;
			}
			.gallery-item img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.8s ease;
			}
			.gallery-item::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(180deg, transparent 0%, rgba(38,14,38,0.6) 100%);
				opacity: 0;
				transition: opacity 0.4s;
			}
			.gallery-item:hover img { transform: scale(1.12); }
			.gallery-item:hover::after { opacity: 1; }
			.gallery-grid-2 {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 24px;
				margin-top: 60px;
			}
			.gallery-grid-2 img {
				width: 100%;
				height: 500px;
				object-fit: cover;
				transition: transform 0.8s ease;
			}
			.gallery-grid-2 img:hover { transform: scale(1.03); }
			.gallery-grid-3 {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				margin-top: 60px;
			}
			.gallery-grid-3 .gallery-item img { height: 380px; }

			/* ======= FULL-WIDTH IMAGE ======= */
			.full-width-image {
				width: 100%;
				height: 70vh;
				min-height: 500px;
				object-fit: cover;
				display: block;
			}
			.image-banner {
				position: relative;
				height: 60vh;
				min-height: 450px;
				background-size: cover;
				background-position: center;
				background-attachment: fixed;
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--cream);
				text-align: center;
			}
			.image-banner::before {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(135deg, rgba(20,8,16,0.7) 0%, rgba(38,14,38,0.5) 100%);
			}
			.image-banner-content {
				position: relative;
				z-index: 2;
				padding: 32px;
				max-width: 800px;
			}
			.image-banner h2 {
				color: var(--cream);
				font-size: 56px;
				font-style: italic;
				font-weight: 300;
				margin-bottom: 16px;
			}
			.image-banner h2 em { color: var(--gold-light); }
			.image-banner p {
				font-family: 'Cormorant Garamond', serif;
				font-size: 22px;
				font-style: italic;
				color: rgba(255,244,233,0.9);
			}

			/* ======= TESTIMONIAL ======= */
			.testimonial-block {
				text-align: center;
				max-width: 780px;
				margin: 0 auto;
			}
			.testimonial-quote {
				font-family: 'Cormorant Garamond', serif;
				font-size: 32px;
				font-style: italic;
				font-weight: 300;
				line-height: 1.5;
				color: var(--gold-light);
				margin-bottom: 32px;
				position: relative;
			}
			.testimonial-quote::before {
				content: '"';
				font-size: 120px;
				color: var(--gold);
				opacity: 0.2;
				position: absolute;
				top: -40px;
				left: -20px;
				font-family: 'Cormorant Garamond', serif;
			}
			.testimonial-author {
				font-size: 13px;
				letter-spacing: 3px;
				text-transform: uppercase;
				color: var(--gold);
				font-weight: 500;
			}

			/* ======= FAQ ======= */
			.faq-list { max-width: 860px; margin: 60px auto 0; }
			.faq-item {
				background: white;
				padding: 32px 40px;
				margin-bottom: 16px;
				border-left: 2px solid var(--gold);
				transition: all 0.4s ease;
			}
			.faq-item:hover {
				box-shadow: 0 8px 30px rgba(38,14,38,0.08);
				transform: translateX(5px);
				border-left-width: 4px;
			}
			.faq-item h3 {
				font-size: 22px;
				margin-bottom: 12px;
				color: var(--plum);
				font-weight: 500;
			}
			.faq-item p {
				font-size: 15px;
				color: rgba(50,34,28,0.8);
				margin: 0;
				line-height: 1.8;
			}

			/* ======= CTA SECTION ======= */
			.cta-section {
				background: linear-gradient(135deg, var(--plum-deep) 0%, var(--plum) 100%);
				padding: 120px 32px;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.cta-section::before {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at center, rgba(166,138,91,0.1) 0%, transparent 70%);
			}
			.cta-section > * { position: relative; z-index: 2; }
			.cta-section h2 {
				font-size: 56px;
				color: var(--cream);
				font-weight: 300;
				font-style: italic;
				margin-bottom: 24px;
			}
			.cta-section h2 em { color: var(--gold-light); }
			.cta-section p {
				font-size: 18px;
				color: rgba(255,244,233,0.8);
				max-width: 600px;
				margin: 0 auto 40px;
				font-family: 'Cormorant Garamond', serif;
				font-style: italic;
			}

			/* ======= ALT ROW ======= */
			.alt-row {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 80px;
				align-items: center;
				margin-bottom: 120px;
			}
			.alt-row:last-child { margin-bottom: 0; }
			.alt-row.reverse > div:first-child { order: 2; }
			.alt-row-img { height: 500px; overflow: hidden; }
			.alt-row-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 1s ease;
			}
			.alt-row-img:hover img { transform: scale(1.05); }
			.alt-row-content h2 { font-size: 42px; font-weight: 400; line-height: 1.2; margin-bottom: 20px; }
			.alt-row-content h2 em { color: var(--gold); font-style: italic; }
			.alt-row-content p { font-size: 16px; line-height: 1.9; margin-bottom: 16px; }

			/* ======= FOOTER ======= */
			.site-footer {
				background: linear-gradient(180deg, var(--plum) 0%, var(--plum-deep) 100%);
				color: var(--cream);
				padding: 80px 32px 0;
				position: relative;
				border-top: 1px solid rgba(166,138,91,0.2);
			}
			.footer-logo {
				text-align: center;
				margin-bottom: 48px;
			}
			.footer-logo .logo {
				display: inline-flex;
				align-items: center;
				flex-direction: column;
			}
			.footer-inner {
				max-width: 1200px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 48px;
				text-align: center;
				justify-items: center;
				padding-bottom: 48px;
			}
			.footer-col h4 {
				color: var(--gold);
				font-family: 'Montserrat', sans-serif;
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 4px;
				font-weight: 500;
				margin-bottom: 20px;
			}
			.footer-col a {
				display: block;
				color: rgba(255,244,233,0.65);
				margin-bottom: 10px;
				font-size: 13px;
				font-weight: 300;
				letter-spacing: 1px;
				transition: color 0.3s, padding-left 0.3s;
			}
			.footer-col a:hover {
				color: var(--gold-light);
				padding-left: 4px;
			}
			.footer-col p {
				color: rgba(255,244,233,0.65);
				font-size: 13px;
				font-weight: 300;
				letter-spacing: 0.5px;
			}
			.footer-cta {
				display: inline-block !important;
				color: var(--gold-light) !important;
				font-weight: 500 !important;
				border-bottom: 1px solid var(--gold);
				padding-bottom: 2px;
				margin-top: 12px;
			}
			.footer-bottom {
				border-top: 1px solid rgba(166,138,91,0.15);
				padding: 24px 0;
				text-align: center;
			}
			.footer-bottom p {
				color: rgba(255,244,233,0.4);
				font-size: 11px;
				letter-spacing: 2px;
				text-transform: uppercase;
				font-weight: 300;
			}

			/* ======= RESPONSIVE ======= */
			@media (max-width: 900px) {
				.hero h1 { font-size: 44px; }
				.intro-block h2, .experience-content h2, .cta-section h2, .image-banner h2 { font-size: 34px; }
				.experience { grid-template-columns: 1fr; gap: 48px; }
				.experience-img { height: 400px; }
				.gallery-grid { grid-template-columns: repeat(2, 1fr); }
				.gallery-grid-3 { grid-template-columns: 1fr; }
				.gallery-grid-3 .gallery-item img { height: 300px; }
				.gallery-grid-2 { grid-template-columns: 1fr; }
				.gallery-grid-2 img { height: 350px; }
				.section { padding: 80px 24px; }
				.cta-section { padding: 80px 24px; }
				.main-nav { gap: 14px; justify-content: center; width: 100%; }
				.main-nav a { font-size: 10px; letter-spacing: 1.5px; }
				.testimonial-quote { font-size: 22px; }
				.alt-row { grid-template-columns: 1fr; gap: 40px; margin-bottom: 80px; }
				.alt-row.reverse > div:first-child { order: 0; }
				.alt-row-img { height: 350px; }
				.alt-row-content h2 { font-size: 32px; }
				.image-banner { height: 50vh; min-height: 350px; background-attachment: scroll; }
				.full-width-image { height: 50vh; min-height: 350px; }
			}
		</style>

		<script>
			// Scroll-triggered reveal animations
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

			document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => {
				observer.observe(el);
			});
		</script>
	</body>
</html>
