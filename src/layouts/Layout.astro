---
const {
	title = "Sula Catering Vancouver | Award-Winning Indian Catering for Weddings, Corporate & Events",
	description = "Vancouver's most trusted Indian catering since 2010. Award-winning wedding, corporate, and private party catering. Halal, vegetarian, vegan options. Get a custom quote.",
	canonical = "/",
	ogImage = "https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/vancouver-catering-sula-indian-restaurant.webp"
} = Astro.props;
const fullCanonical = `https://sulacatering.com${canonical}`;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="canonical" href={fullCanonical} />
		<link rel="icon" type="image/png" href="https://sulaindianrestaurant.com/images/logos/logo-icon.png" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={fullCanonical} />
		<meta property="og:site_name" content="Sula Catering Vancouver" />
		<meta property="og:locale" content="en_CA" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="geo.region" content="CA-BC" />
		<meta name="geo.placename" content="Vancouver" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Montserrat:wght@200;300;400;500;600;700&display=swap" rel="stylesheet" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FoodEstablishment",
			"@id": "https://sulacatering.com/#organization",
			"name": "Sula Catering Vancouver",
			"url": "https://sulacatering.com",
			"telephone": "+1-604-215-1130",
			"email": "catering@sulaindianrestaurant.com",
			"priceRange": "$$-$$$",
			"servesCuisine": ["Indian", "South Asian", "North Indian", "South Indian"],
			"address": {"@type": "PostalAddress","streetAddress": "1128 Commercial Drive","addressLocality": "Vancouver","addressRegion": "BC","postalCode": "V5L 3X2","addressCountry": "CA"},
			"areaServed": [{"@type": "City", "name": "Vancouver"},{"@type": "City", "name": "Burnaby"},{"@type": "City", "name": "Richmond"},{"@type": "City", "name": "Surrey"},{"@type": "City", "name": "North Vancouver"},{"@type": "City", "name": "West Vancouver"}],
			"sameAs": ["https://sulaindianrestaurant.com","https://www.instagram.com/sulaindianrestaurant"],
			"image": "https://backend.sulaindianrestaurant.com/wp-content/uploads/2026/03/vancouver-catering-sula-indian-restaurant.webp"
		})} />
		<slot name="schema" />
	</head>
	<body>
		<header class="site-header">
			<div class="header-inner">
				<a href="/" class="logo" aria-label="Sula Catering Home">
					<img src="https://sulaindianrestaurant.com/images/logos/logo-sula.png" alt="Sula Catering Vancouver" class="logo-img" />
				</a>
				<nav class="main-nav" aria-label="Main navigation">
					<a href="/">Home</a>
					<a href="/weddings">Weddings</a>
					<a href="/corporate">Corporate</a>
					<a href="/private-parties">Private</a>
					<a href="/cafe-catering">Café</a>
					<a href="/gallery">Gallery</a>
					<a href="/blog">Journal</a>
					<a href="https://sulaindianrestaurant.com/request-a-quote/" class="cta">Get a Quote</a>
				</nav>
			</div>
		</header>
		<main><slot /></main>
		<footer class="site-footer">
			<div class="footer-logo reveal">
				<a href="/" aria-label="Sula Catering Home">
					<img src="https://sulaindianrestaurant.com/images/logos/logo-sula.png" alt="Sula Catering Vancouver" class="footer-logo-img" />
				</a>
				<p class="footer-tag">Catering · Vancouver</p>
				<div class="gold-divider-ornament"><span></span><div class="diamond"></div><span></span></div>
			</div>
			<div class="footer-inner">
				<div class="footer-col">
					<h4>Sula Catering</h4>
					<p>Award-winning Indian catering across Vancouver, Burnaby, Richmond, Surrey & North Vancouver since 2010.</p>
				</div>
				<div class="footer-col">
					<h4>Services</h4>
					<a href="/weddings">Wedding Catering</a>
					<a href="/corporate">Corporate Catering</a>
					<a href="/private-parties">Private Parties</a>
					<a href="/cafe-catering">Café & Chai Catering</a>
					<a href="/gallery">Gallery</a>
					<a href="/blog">Journal</a>
				</div>
				<div class="footer-col">
					<h4>Contact</h4>
					<p>604-215-1130<br/>catering@sulaindianrestaurant.com</p>
					<a href="https://sulaindianrestaurant.com/request-a-quote/" class="footer-cta">Request a Quote →</a>
				</div>
				<div class="footer-col">
					<h4>Visit Sula</h4>
					<a href="https://sulaindianrestaurant.com" target="_blank" rel="noopener" class="footer-visit-btn">Sula Indian Restaurant ↗</a>
					<a href="https://sulacafe.com" target="_blank" rel="noopener" class="footer-visit-btn">Sula Café ↗</a>
				</div>
			</div>
			<div class="footer-bottom"><p>© 2026 Sula Indian Restaurant · All Rights Reserved</p></div>
		</footer>

		<style is:global>
			:root {
				--midnight:#0a1628; --midnight-deep:#050b15; --navy:#142442; --navy-mid:#1c2f54;
				--plum:#25042d; --plum-mid:#3d1042; --plum-rich:#4a1554;
				--gold:#b8956a; --gold-light:#d4b572; --gold-shimmer:#e8c987;
				--cream:#f5ede0; --cream-soft:#ede4d3; --dark-text:#1a1a1a;
			}
			*{box-sizing:border-box;margin:0;padding:0}
			html,body{overflow-x:hidden;scroll-behavior:smooth}
			body{font-family:'Montserrat',sans-serif;font-weight:300;color:var(--dark-text);background:var(--cream);line-height:1.7;letter-spacing:0.3px}
			img{max-width:100%;height:auto;display:block}
			a{color:var(--gold);text-decoration:none}
			h1,h2,h3,h4{font-family:'Cormorant Garamond',serif;font-weight:400;color:var(--midnight);letter-spacing:0.5px}
			@keyframes fadeUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
			@keyframes fadeIn{from{opacity:0}to{opacity:1}}
			.reveal{opacity:0;transform:translateY(40px);transition:opacity 1s ease,transform 1s ease}
			.reveal.visible{opacity:1;transform:translateY(0)}
			.reveal-left{opacity:0;transform:translateX(-60px);transition:opacity 1s ease,transform 1s ease}
			.reveal-left.visible{opacity:1;transform:translateX(0)}
			.reveal-right{opacity:0;transform:translateX(60px);transition:opacity 1s ease,transform 1s ease}
			.reveal-right.visible{opacity:1;transform:translateX(0)}
			.reveal-scale{opacity:0;transform:scale(0.95);transition:opacity 1s ease,transform 1s ease}
			.reveal-scale.visible{opacity:1;transform:scale(1)}
			.delay-100{transition-delay:0.1s}.delay-200{transition-delay:0.2s}.delay-300{transition-delay:0.3s}.delay-400{transition-delay:0.4s}

			/* INLINE LINK STYLE - for body keyword anchors */
			.inline-link{color:var(--gold);border-bottom:1px solid rgba(184,149,106,0.4);transition:border-color 0.3s,opacity 0.3s}
			.inline-link:hover{border-bottom-color:var(--gold);opacity:0.8}
			.section-dark .inline-link,.section-plum .inline-link{color:var(--gold-light);border-bottom-color:rgba(212,181,114,0.4)}
			.section-dark .inline-link:hover,.section-plum .inline-link:hover{border-bottom-color:var(--gold-light)}

			/* LABELS */
			.gold-label{display:inline-block;font-family:'Montserrat',sans-serif;font-size:11px;letter-spacing:6px;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:24px}
			.gold-label::before,.gold-label::after{content:'';display:inline-block;width:32px;height:1px;background:var(--gold);vertical-align:middle;margin:0 16px;opacity:0.6}
			.eyebrow{display:block;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;color:var(--gold);letter-spacing:0.5px;margin-bottom:8px;font-weight:400}

			/* DIVIDERS */
			.gold-divider-ornament{display:flex;align-items:center;justify-content:center;margin:32px 0;gap:16px}
			.gold-divider-ornament span{height:1px;width:60px;background:linear-gradient(90deg,transparent,var(--gold))}
			.gold-divider-ornament span:last-child{background:linear-gradient(90deg,var(--gold),transparent)}
			.gold-divider-ornament .diamond{width:8px;height:8px;transform:rotate(45deg);flex-shrink:0;background:linear-gradient(135deg,var(--gold-shimmer),var(--gold))}

			/* HEADER */
			.site-header{background:linear-gradient(135deg,var(--midnight-deep) 0%,var(--midnight) 30%,var(--plum-mid) 70%,var(--plum) 100%);color:var(--cream);padding:16px 0;position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(184,149,106,0.2);box-shadow:0 4px 30px rgba(0,0,0,0.4);animation:fadeIn 0.8s ease}
			.header-inner{max-width:1280px;margin:0 auto;padding:0 32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
			.logo{display:flex;align-items:center;transition:opacity 0.3s}
			.logo:hover{opacity:0.85}
			.logo-img{height:50px;width:auto;display:block}
			.main-nav{display:flex;gap:22px;align-items:center;flex-wrap:wrap}
			.main-nav a{color:var(--cream);font-size:11px;font-weight:400;text-transform:uppercase;letter-spacing:2.5px;position:relative;padding:6px 0;transition:color 0.3s}
			.main-nav a::after{content:'';position:absolute;bottom:0;left:50%;width:0;height:1px;background:var(--gold);transition:all 0.4s ease;transform:translateX(-50%)}
			.main-nav a:hover{color:var(--gold)}
			.main-nav a:hover::after{width:100%}
			.main-nav a.cta{background:linear-gradient(135deg,var(--gold) 0%,var(--gold-light) 100%);color:var(--midnight);padding:12px 24px;font-weight:600;letter-spacing:2px}
			.main-nav a.cta::after{display:none}
			.main-nav a.cta:hover{background:linear-gradient(135deg,var(--gold-light) 0%,var(--gold-shimmer) 100%);transform:translateY(-2px);box-shadow:0 8px 20px rgba(184,149,106,0.4)}

			/* HERO */
			.hero{position:relative;min-height:90vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:80px 32px;color:var(--cream);background-size:cover;background-position:center;overflow:hidden;animation:fadeIn 1.2s ease}
			.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 0%,rgba(5,11,21,0.6) 100%)}
			.hero-content{position:relative;z-index:2;max-width:900px}
			.hero .gold-label{color:var(--gold-light);animation:fadeUp 1s ease 0.3s both}
			.hero h1{font-size:72px;color:var(--cream);font-weight:300;line-height:1.1;margin-bottom:24px;font-style:italic;animation:fadeUp 1.2s ease 0.5s both}
			.hero h1 em{color:var(--gold-light);font-style:italic;font-weight:400}
			.hero-tagline{font-size:20px;font-weight:300;max-width:680px;margin:0 auto 40px;opacity:0.92;font-style:italic;font-family:'Cormorant Garamond',serif;animation:fadeUp 1.2s ease 0.8s both}
			.hero .btn{animation:fadeUp 1.2s ease 1.1s both}

			/* BUTTONS */
			.btn{display:inline-block;padding:18px 40px;font-family:'Montserrat',sans-serif;font-weight:500;letter-spacing:3px;text-transform:uppercase;font-size:12px;transition:all 0.4s ease;cursor:pointer;border:none;position:relative;overflow:hidden}
			.btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);transition:left 0.6s ease}
			.btn:hover::before{left:100%}
			.btn-gold{background:linear-gradient(135deg,var(--gold) 0%,var(--gold-light) 100%);color:var(--midnight);border:1px solid var(--gold)}
			.btn-gold:hover{background:linear-gradient(135deg,var(--gold-shimmer) 0%,var(--gold-light) 100%);transform:translateY(-3px);box-shadow:0 12px 30px rgba(184,149,106,0.5)}
			.btn-outline{background:transparent;color:var(--cream);border:1px solid var(--gold)}
			.btn-outline:hover{background:var(--gold);color:var(--midnight);transform:translateY(-3px)}
			.btn-outline-dark{background:transparent;color:var(--midnight);border:1px solid var(--midnight)}
			.btn-outline-dark:hover{background:var(--midnight);color:var(--cream);transform:translateY(-3px)}

			/* SECTIONS */
			.section{padding:120px 32px}
			.section-tight{padding:80px 32px}
			.container{max-width:1280px;margin:0 auto}
			.container-narrow{max-width:980px;margin:0 auto}
			.text-center{text-align:center}
			.section-cream{background:linear-gradient(180deg,var(--cream) 0%,var(--cream-soft) 100%);position:relative}
			.section-dark{background:linear-gradient(135deg,var(--midnight-deep) 0%,var(--midnight) 30%,var(--navy) 60%,var(--plum) 100%);color:var(--cream);position:relative;overflow:hidden}
			.section-dark::before,.section-dark::after{content:'';position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
			.section-dark::before{top:0}
			.section-dark::after{bottom:0}
			.section-dark h1,.section-dark h2,.section-dark h3{color:var(--gold-light)}
			.section-dark p{color:rgba(245,237,224,0.85)}
			.section-plum{background:linear-gradient(135deg,var(--plum) 0%,var(--plum-rich) 50%,var(--plum-mid) 100%);color:var(--cream);position:relative;overflow:hidden}
			.section-plum::before,.section-plum::after{content:'';position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
			.section-plum::before{top:0}
			.section-plum::after{bottom:0}
			.section-plum h1,.section-plum h2,.section-plum h3{color:var(--gold-light)}
			.section-plum p{color:rgba(245,237,224,0.85)}

			/* INTRO BLOCK */
			.intro-block{text-align:center;max-width:820px;margin:0 auto}
			.intro-block h2{font-size:48px;font-weight:400;margin-bottom:16px;line-height:1.2}
			.intro-block h2 em{color:var(--gold);font-weight:400;font-style:italic}
			.section-dark .intro-block h2 em,.section-plum .intro-block h2 em{color:var(--gold-light)}
			.intro-block p{font-size:17px;line-height:1.9;color:var(--dark-text);font-weight:300}
			.section-dark .intro-block p,.section-plum .intro-block p{color:rgba(245,237,224,0.85)}

			/* MAGAZINE TITLE */
			.mag-title{font-size:56px;font-weight:400;line-height:1.1;letter-spacing:0.5px;text-align:center}
			.mag-title em{color:var(--gold);font-style:italic;font-weight:500}
			.section-dark .mag-title em,.section-plum .mag-title em{color:var(--gold-light)}

			/* SERVICE CARDS V2 */
			.service-grid-v2{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:80px}
			.service-card-v2{position:relative;display:block;overflow:hidden;color:inherit;text-decoration:none;aspect-ratio:4/3;transition:transform 0.5s ease}
			.service-card-v2:hover{transform:translateY(-6px)}
			.service-card-img{position:relative;width:100%;height:100%;overflow:hidden}
			.service-card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.8s ease}
			.service-card-v2:hover .service-card-img img{transform:scale(1.08)}
			.service-card-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,22,40,0.1) 0%,rgba(10,22,40,0.5) 50%,rgba(20,8,16,0.92) 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:48px 40px;color:var(--cream)}
			.service-eyebrow{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:16px;color:var(--gold-light);letter-spacing:1px;margin-bottom:8px;font-weight:400;display:block}
			.service-card-v2 h3{font-size:36px;color:var(--cream);margin-bottom:12px;font-weight:400;line-height:1.1}
			.service-card-v2 h3 em{color:var(--gold-light);font-style:italic;font-weight:500}
			.service-card-v2 p{font-size:15px;color:rgba(245,237,224,0.85);line-height:1.6;margin-bottom:16px;max-width:420px}
			.service-arrow{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:14px;letter-spacing:2px;text-transform:uppercase;color:var(--gold-light);font-weight:500;transition:letter-spacing 0.3s,padding-left 0.3s}
			.service-card-v2:hover .service-arrow{letter-spacing:4px;padding-left:6px}

			/* EXPERIENCE / ALT-ROW */
			.experience{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
			.experience-img{position:relative;height:600px;overflow:hidden}
			.experience-img::before{content:'';position:absolute;top:20px;left:20px;right:-20px;bottom:-20px;border:1px solid var(--gold);z-index:-1;transition:all 0.6s ease}
			.experience-img:hover::before{top:30px;left:30px;right:-30px;bottom:-30px}
			.experience-img img{width:100%;height:100%;object-fit:cover;transition:transform 1s ease}
			.experience-img:hover img{transform:scale(1.05)}
			.experience-content{text-align:left}
			.experience-content h2{font-size:48px;margin-bottom:24px;font-weight:400;line-height:1.2;text-align:left}
			.experience-content h2 em{color:var(--gold);font-style:italic}
			.section-dark .experience-content h2,.section-plum .experience-content h2{color:var(--gold-light)}
			.section-dark .experience-content h2 em,.section-plum .experience-content h2 em{color:var(--gold)}
			.experience-content p{font-size:16px;line-height:1.9;margin-bottom:20px;text-align:left}
			.experience-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:48px;padding-top:40px;border-top:1px solid rgba(184,149,106,0.3)}
			.stat-item{text-align:center;transition:transform 0.4s ease}
			.stat-item:hover{transform:translateY(-5px)}
			.stat-number{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:400;color:var(--gold-light);line-height:1;margin-bottom:8px}
			.section-cream .stat-number{color:var(--gold)}
			.stat-label{font-size:11px;text-transform:uppercase;letter-spacing:2px;color:var(--gold);font-weight:500}

			.alt-row{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-bottom:120px}
			.alt-row:last-child{margin-bottom:0}
			.alt-row.reverse > div:first-child{order:2}
			.alt-row-img{height:520px;overflow:hidden;position:relative}
			.alt-row-img img{width:100%;height:100%;object-fit:cover;transition:transform 1s ease}
			.alt-row-img:hover img{transform:scale(1.05)}
			.alt-row-content{text-align:left}
			.alt-row-content h2{font-size:42px;font-weight:400;line-height:1.2;margin-bottom:20px;text-align:left}
			.alt-row-content h2 em{color:var(--gold);font-style:italic}
			.section-dark .alt-row-content h2,.section-plum .alt-row-content h2{color:var(--gold-light)}
			.section-dark .alt-row-content h2 em,.section-plum .alt-row-content h2 em{color:var(--gold)}
			.alt-row-content p{font-size:16px;line-height:1.9;margin-bottom:16px;text-align:left}

			/* GALLERY */
			.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:60px}
			.gallery-item{position:relative;aspect-ratio:1;overflow:hidden;cursor:pointer}
			.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform 0.8s ease}
			.gallery-item::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 0%,rgba(10,22,40,0.6) 100%);opacity:0;transition:opacity 0.4s}
			.gallery-item:hover img{transform:scale(1.12)}
			.gallery-item:hover::after{opacity:1}
			.gallery-grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:60px}
			.gallery-grid-2 .gallery-item{aspect-ratio:16/10}
			.gallery-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:60px}
			.gallery-grid-3 .gallery-item{aspect-ratio:4/3}

			/* FULL-WIDTH IMAGE & BANNERS */
			.full-width-image{width:100%;height:70vh;min-height:500px;object-fit:cover;display:block}
			.image-banner{position:relative;height:60vh;min-height:450px;background-size:cover;background-position:center;background-attachment:fixed;display:flex;align-items:center;justify-content:center;color:var(--cream);text-align:center}
			.image-banner::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(5,11,21,0.75) 0%,rgba(37,4,45,0.55) 100%)}
			.image-banner-plum::before{background:linear-gradient(135deg,rgba(37,4,45,0.85) 0%,rgba(74,21,84,0.6) 100%)}
			.image-banner-content{position:relative;z-index:2;padding:32px;max-width:800px}
			.image-banner h2{color:var(--cream);font-size:56px;font-style:italic;font-weight:300;margin-bottom:16px}
			.image-banner h2 em{color:var(--gold-light)}
			.image-banner p{font-family:'Cormorant Garamond',serif;font-size:22px;font-style:italic;color:rgba(245,237,224,0.9)}

			/* TESTIMONIAL */
			.testimonial-block{text-align:center;max-width:780px;margin:0 auto}
			.testimonial-quote{font-family:'Cormorant Garamond',serif;font-size:32px;font-style:italic;font-weight:300;line-height:1.5;color:var(--gold-light);margin-bottom:32px;position:relative}
			.testimonial-quote::before{content:'"';font-size:120px;color:var(--gold);opacity:0.2;position:absolute;top:-40px;left:-20px;font-family:'Cormorant Garamond',serif}
			.testimonial-author{font-size:13px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:500}

			/* PULL QUOTE */
			.pull-quote{max-width:860px;margin:0 auto;text-align:center;padding:60px 40px;border-top:1px solid rgba(184,149,106,0.3);border-bottom:1px solid rgba(184,149,106,0.3)}
			.pull-quote-text{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:36px;line-height:1.4;font-weight:300;color:var(--midnight);margin-bottom:20px}
			.pull-quote-text em{color:var(--gold)}
			.section-dark .pull-quote-text,.section-plum .pull-quote-text{color:var(--gold-light)}
			.pull-quote-attribution{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:500}

			/* NUMBERED LIST */
			.numbered-list{max-width:900px;margin:60px auto 0}
			.numbered-item{display:grid;grid-template-columns:80px 1fr;gap:32px;align-items:flex-start;padding:32px 0;border-bottom:1px solid rgba(184,149,106,0.15);text-align:left}
			.numbered-item:last-child{border-bottom:none}
			.numbered-num{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:48px;font-weight:300;color:var(--gold);line-height:1}
			.numbered-content h3{font-size:24px;font-weight:500;margin-bottom:8px;color:var(--midnight);text-align:left}
			.section-dark .numbered-content h3,.section-plum .numbered-content h3{color:var(--gold-light)}
			.numbered-content h3 em{color:var(--gold);font-style:italic}
			.numbered-content p{font-size:15px;line-height:1.8;color:rgba(26,26,26,0.75);text-align:left}
			.section-dark .numbered-content p,.section-plum .numbered-content p{color:rgba(245,237,224,0.8)}

			/* FAQ */
			.faq-list{max-width:860px;margin:60px auto 0}
			.faq-item{background:white;padding:32px 40px;margin-bottom:16px;border-left:2px solid var(--gold);transition:all 0.4s ease;text-align:left}
			.section-dark .faq-item,.section-plum .faq-item{background:rgba(255,255,255,0.05);backdrop-filter:blur(10px)}
			.faq-item:hover{box-shadow:0 8px 30px rgba(10,22,40,0.08);transform:translateX(5px);border-left-width:4px}
			.faq-item h3{font-size:22px;margin-bottom:12px;color:var(--midnight);font-weight:500;text-align:left}
			.section-dark .faq-item h3,.section-plum .faq-item h3{color:var(--gold-light)}
			.faq-item p{font-size:15px;color:rgba(26,26,26,0.8);margin:0;line-height:1.8;text-align:left}
			.section-dark .faq-item p,.section-plum .faq-item p{color:rgba(245,237,224,0.8)}

			/* CTA */
			.cta-section{background:linear-gradient(135deg,var(--midnight-deep) 0%,var(--navy) 50%,var(--plum) 100%);padding:120px 32px;text-align:center;position:relative;overflow:hidden}
			.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at center,rgba(184,149,106,0.1) 0%,transparent 70%)}
			.cta-section > *{position:relative;z-index:2}
			.cta-section h2{font-size:56px;color:var(--cream);font-weight:300;font-style:italic;margin-bottom:24px}
			.cta-section h2 em{color:var(--gold-light)}
			.cta-section p{font-size:18px;color:rgba(245,237,224,0.8);max-width:600px;margin:0 auto 40px;font-family:'Cormorant Garamond',serif;font-style:italic}
			.cta-plum{background:linear-gradient(135deg,var(--plum) 0%,var(--plum-rich) 50%,var(--plum-mid) 100%)}

			/* RELATED LINKS */
			.related-links{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-top:60px}
			.related-link{background:rgba(255,255,255,0.05);backdrop-filter:blur(10px);padding:32px 28px;border:1px solid rgba(184,149,106,0.2);transition:all 0.4s ease;text-align:left;display:block;color:inherit}
			.section-cream .related-link{background:white;border-color:rgba(184,149,106,0.15)}
			.related-link:hover{border-color:var(--gold);transform:translateY(-4px);box-shadow:0 12px 30px rgba(10,22,40,0.1)}
			.related-link .meta{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:8px;font-weight:500}
			.related-link h4{font-size:20px;margin-bottom:8px;font-weight:500;color:var(--midnight);font-family:'Cormorant Garamond',serif}
			.section-dark .related-link h4,.section-plum .related-link h4{color:var(--gold-light)}
			.related-link h4 em{color:var(--gold);font-style:italic}
			.related-link p{font-size:14px;line-height:1.7;color:rgba(26,26,26,0.7)}
			.section-dark .related-link p,.section-plum .related-link p{color:rgba(245,237,224,0.7)}
			.related-link .arrow{display:inline-block;margin-top:12px;font-family:'Cormorant Garamond',serif;font-style:italic;color:var(--gold);font-size:13px;letter-spacing:1px;font-weight:500}

			/* BLOG CARDS */
			.blog-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:40px;margin-top:80px}
			.blog-card{background:white;overflow:hidden;transition:all 0.5s ease;border:1px solid rgba(184,149,106,0.15);display:block;color:inherit;text-decoration:none}
			.blog-card:hover{transform:translateY(-8px);box-shadow:0 20px 50px rgba(10,22,40,0.12);border-color:var(--gold)}
			.blog-card-img{width:100%;aspect-ratio:16/10;overflow:hidden}
			.blog-card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.8s ease}
			.blog-card:hover .blog-card-img img{transform:scale(1.05)}
			.blog-card-content{padding:32px}
			.blog-card-meta{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:12px;font-weight:500}
			.blog-card h3{font-size:26px;margin-bottom:12px;line-height:1.3;font-weight:500;color:var(--midnight)}
			.blog-card h3 em{color:var(--gold);font-style:italic}
			.blog-card p{font-size:15px;color:rgba(26,26,26,0.7);line-height:1.8;margin-bottom:16px}
			.blog-card .read-more{font-family:'Cormorant Garamond',serif;font-style:italic;color:var(--gold);font-size:15px;letter-spacing:1px;font-weight:500}

			/* BLOG POST */
			.blog-post{max-width:780px;margin:0 auto;padding:0 32px}
			.blog-post p{font-size:17px;line-height:1.9;margin-bottom:24px;color:var(--dark-text)}
			.blog-post h2{font-size:36px;margin:48px 0 20px;color:var(--midnight);font-weight:400}
			.blog-post h2 em{color:var(--gold);font-style:italic}
			.blog-post h3{font-size:26px;margin:32px 0 16px;color:var(--midnight);font-weight:500}
			.blog-post ul{list-style:none;padding:0;margin:0 0 24px}
			.blog-post ul li{padding:8px 0 8px 28px;position:relative;font-size:16px;line-height:1.8}
			.blog-post ul li::before{content:'◆';position:absolute;left:0;color:var(--gold);font-size:10px;top:14px}
			.blog-post a{color:var(--gold);border-bottom:1px solid rgba(184,149,106,0.4);transition:opacity 0.3s,border-color 0.3s}
			.blog-post a:hover{opacity:0.7;border-bottom-color:var(--gold)}
			.blog-post-meta{text-align:center;margin-bottom:48px;padding-bottom:32px;border-bottom:1px solid rgba(184,149,106,0.3)}
			.blog-post-meta .meta-info{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);font-weight:500}

			/* CONTACT CARDS */
			.contact-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:32px;margin-top:60px}
			.contact-card{background:white;padding:48px 32px;text-align:center;border:1px solid rgba(184,149,106,0.2);transition:all 0.5s ease}
			.contact-card:hover{transform:translateY(-8px);box-shadow:0 20px 50px rgba(10,22,40,0.12);border-color:var(--gold)}
			.contact-card .icon{font-size:32px;color:var(--gold);margin-bottom:20px;font-family:'Cormorant Garamond',serif;font-style:italic}
			.contact-card h3{font-size:22px;margin-bottom:12px;font-weight:500}
			.contact-card p{font-size:15px;color:rgba(26,26,26,0.75);margin-bottom:16px;line-height:1.7}
			.contact-card a{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;color:var(--gold);font-weight:500;border-bottom:1px solid var(--gold);padding-bottom:2px}

			/* LOCATIONS */
			.locations-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:32px;margin-top:60px}
			.location-card{background:rgba(255,255,255,0.05);backdrop-filter:blur(10px);padding:36px 28px;text-align:center;border:1px solid rgba(184,149,106,0.2);transition:all 0.4s ease}
			.location-card:hover{border-color:var(--gold);transform:translateY(-6px);background:rgba(255,255,255,0.08)}
			.location-card h3{font-size:22px;color:var(--gold-light);margin-bottom:8px;font-weight:500}
			.location-card .addr{font-size:13px;color:rgba(245,237,224,0.7);line-height:1.7;margin-bottom:12px}
			.location-card .phone{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;color:var(--gold);font-weight:500}

			/* FOOTER */
			.site-footer{background:linear-gradient(180deg,var(--midnight) 0%,var(--midnight-deep) 100%);color:var(--cream);padding:80px 32px 0;border-top:1px solid rgba(184,149,106,0.2)}
			.footer-logo{text-align:center;margin-bottom:48px}
			.footer-logo-img{height:80px;width:auto;display:inline-block}
			.footer-tag{margin-top:16px;font-size:11px;letter-spacing:6px;text-transform:uppercase;color:var(--gold);font-family:'Cormorant Garamond',serif;font-style:italic}
			.footer-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:48px;text-align:center;justify-items:center;padding-bottom:48px}
			.footer-col h4{color:var(--gold);font-family:'Montserrat',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:4px;font-weight:500;margin-bottom:20px}
			.footer-col a{display:block;color:rgba(245,237,224,0.65);margin-bottom:10px;font-size:13px;font-weight:300;letter-spacing:1px;transition:color 0.3s,padding-left 0.3s}
			.footer-col a:hover{color:var(--gold-light);padding-left:4px}
			.footer-col p{color:rgba(245,237,224,0.65);font-size:13px;font-weight:300;letter-spacing:0.5px}
			.footer-cta{display:inline-block !important;color:var(--gold-light) !important;font-weight:500 !important;border-bottom:1px solid var(--gold);padding-bottom:2px;margin-top:12px}
			.footer-visit-btn{display:inline-block !important;padding:10px 20px !important;border:1px solid var(--gold) !important;color:var(--gold-light) !important;font-size:11px !important;letter-spacing:2px !important;text-transform:uppercase !important;font-weight:500 !important;margin-bottom:12px !important;transition:all 0.4s ease !important}
			.footer-visit-btn:hover{background:var(--gold) !important;color:var(--midnight) !important;padding-left:20px !important;transform:translateY(-2px)}
			.footer-bottom{border-top:1px solid rgba(184,149,106,0.15);padding:24px 0;text-align:center}
			.footer-bottom p{color:rgba(245,237,224,0.4);font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:300}

			/* RESPONSIVE */
			@media (max-width:900px){
				.logo-img{height:40px}
				.hero h1{font-size:44px}
				.intro-block h2,.experience-content h2,.cta-section h2,.image-banner h2,.mag-title{font-size:34px}
				.experience{grid-template-columns:1fr;gap:48px}
				.experience-img{height:400px}
				.experience-content,.experience-content h2,.experience-content p{text-align:center}
				.gallery-grid{grid-template-columns:repeat(2,1fr)}
				.gallery-grid-3{grid-template-columns:1fr}
				.gallery-grid-2{grid-template-columns:1fr}
				.section{padding:80px 24px}
				.section-tight{padding:60px 24px}
				.cta-section{padding:80px 24px}
				.service-grid-v2{grid-template-columns:1fr;gap:24px}
				.service-card-overlay{padding:32px 24px}
				.service-card-v2 h3{font-size:28px}
				.main-nav{gap:14px;justify-content:center;width:100%}
				.main-nav a{font-size:10px;letter-spacing:1.5px}
				.testimonial-quote{font-size:22px}
				.alt-row{grid-template-columns:1fr;gap:40px;margin-bottom:80px}
				.alt-row.reverse > div:first-child{order:0}
				.alt-row-img{height:350px}
				.alt-row-content,.alt-row-content h2,.alt-row-content p{text-align:center}
				.alt-row-content h2{font-size:30px;line-height:1.25;hyphens:none;word-break:normal;overflow-wrap:break-word}
				.image-banner{height:50vh;min-height:350px;background-attachment:scroll}
				.full-width-image{height:50vh;min-height:350px}
				.numbered-item{grid-template-columns:1fr;gap:8px;text-align:center}
				.numbered-num{text-align:center}
				.numbered-content h3,.numbered-content p{text-align:center}
				.pull-quote-text{font-size:24px}
				.blog-post h2{font-size:28px}
			}
		</style>
		<script>
			const observer = new IntersectionObserver((entries)=>{
				entries.forEach(entry=>{
					if(entry.isIntersecting){
						entry.target.classList.add('visible');
						observer.unobserve(entry.target);
					}
				});
			},{threshold:0.15,rootMargin:'0px 0px -50px 0px'});
			document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale').forEach(el=>observer.observe(el));
		</script>
	</body>
</html>
